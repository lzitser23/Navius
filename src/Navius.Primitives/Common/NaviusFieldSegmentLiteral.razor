@namespace Navius.Primitives.Common
@inherits ComponentBase

@*
    A non-interactive separator between two segments (the "/", "." or ":"). Hidden from
    assistive tech (aria-hidden) and never focusable, matching react-aria's treatment of
    literal segments. Emits the discrete data-navius-<part>-literal test hook.
*@

<span aria-hidden="true" data-segment="literal" @attributes="_hook">@Text</span>

@code {
    [CascadingParameter] public SegmentFieldContext Ctx { get; set; } = default!;

    /// <summary>The separator characters to render.</summary>
    [Parameter] public string Text { get; set; } = "";

    private Dictionary<string, object> _hook = new();

    protected override void OnParametersSet() =>
        _hook = new Dictionary<string, object> { [$"data-navius-{Ctx.PartName}-literal"] = "" };
}
