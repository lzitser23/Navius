@namespace Navius.Primitives.Components.Tooltip

@*
    The spec Tooltip.Portal. A flag-setter: records the custom mount container +
    keepMounted into the context; the Popup performs the teleport via <NaviusPortal>.
    Renders no DOM of its own.
*@

@ChildContent

@code {
    [CascadingParameter] private TooltipContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>CSS selector of a custom mount container; null teleports into <c>document.body</c>.</summary>
    [Parameter] public string? Container { get; set; }

    /// <summary>Keep the popup mounted while the tooltip is closed (for exit animations).</summary>
    [Parameter] public bool KeepMounted { get; set; }

    protected override void OnParametersSet()
    {
        Context.PortalContainer = Container;
        Context.PortalKeepMounted = KeepMounted;
    }
}
