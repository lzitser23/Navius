@namespace Navius.Primitives.Components.Form
@inherits ComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JS

@*
    Base UI Form.Root — a native <form> that consolidates validation and an
    errors-by-name map. Owns a FormContext registry of fields and cascades it.

    Errors flow (mirrors the spec Form.Root errors / onClearErrors):
      - The `Errors` dict (keyed by field name) is pushed down to each field; a
        Field.Error with no Match surfaces its field's error text.
      - A field auto-clears its error when the user next edits it.
    Submit flow:
      1. OnClearErrors fires (stale errors are cleared before re-validating).
      2. Every field reveals its validity (so onSubmit-mode fields surface).
      3. If any field is invalid, focus moves to the first invalid control and
         OnSubmit is NOT invoked. Otherwise OnSubmit fires.
*@

<CascadingValue Value="_context" IsFixed="true">
    <form @ref="_form"
          data-navius-form
          @onsubmit="HandleSubmitAsync"
          @onsubmit:preventDefault="@PreventDefault"
          @onreset="HandleResetAsync"
          @attributes="Attributes">
        @ChildContent
    </form>
</CascadingValue>

@code {
    private const string ModulePath = "./_content/Navius.Primitives/navius-interop.js";

    /// <summary>Invoked on native form submit when every field is valid. Prevent-default is on by default.</summary>
    [Parameter] public EventCallback OnSubmit { get; set; }

    /// <summary>Validation errors keyed by field name (the spec <c>errors</c>). Surfaced by each field's <c>Error</c>.</summary>
    [Parameter] public IReadOnlyDictionary<string, string[]>? Errors { get; set; }

    /// <summary>Fired before re-validating on submit and on reset, to clear stale errors (the spec <c>onClearErrors</c>).</summary>
    [Parameter] public EventCallback OnClearErrors { get; set; }

    /// <summary>When <c>true</c> (default) the native submit is prevented so the consumer owns submission.</summary>
    [Parameter] public bool PreventDefault { get; set; } = true;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private readonly FormContext _context = new();
    private ElementReference _form;
    private IJSObjectReference? _module;
    private IReadOnlyDictionary<string, string[]>? _lastErrors;

    protected override async Task OnParametersSetAsync()
    {
        // Push errors only when the dict reference changes, so a field's auto-clear
        // (on user edit) isn't immediately re-asserted by the next render.
        if (!ReferenceEquals(Errors, _lastErrors))
        {
            _lastErrors = Errors;
            await _context.ApplyErrorsAsync(Errors);
        }
    }

    private async Task HandleSubmitAsync()
    {
        // 1. Clear stale errors before re-validating.
        await _context.ClearServerErrorsAsync();
        if (OnClearErrors.HasDelegate)
        {
            await OnClearErrors.InvokeAsync();
        }

        // 2. Reveal validity on every field so onSubmit-mode fields surface.
        await _context.RevealAllAsync();

        // 3. Block submission and focus the first invalid control when invalid.
        if (!_context.IsValid)
        {
            await FocusFirstInvalidAsync();
            return;
        }

        if (OnSubmit.HasDelegate)
        {
            await OnSubmit.InvokeAsync();
        }
    }

    private async Task HandleResetAsync()
    {
        await _context.ClearServerErrorsAsync();
        if (OnClearErrors.HasDelegate)
        {
            await OnClearErrors.InvokeAsync();
        }
    }

    private async Task FocusFirstInvalidAsync()
    {
        var field = _context.FirstInvalidField();
        if (field is null)
        {
            return;
        }

        if (field.FocusControl is not null)
        {
            await field.FocusAsync();
            return;
        }

        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", ModulePath);
            await _module.InvokeVoidAsync("focusElementById", field.ControlId);
        }
        catch (JSException)
        {
            // Export unavailable — focus is best-effort.
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }
}
