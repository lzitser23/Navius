@namespace Navius.Primitives.Components.Field
@inherits FieldPart

@*
    Base UI Field.Label — a native <label for> pointing at the control id, so
    clicking the label focuses the control. Reflects the field's discrete state.
*@

<label for="@Field.ControlId"
       data-navius-field-label
       @attributes="Field.MergeState(Attributes)">
    @ChildContent
</label>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
