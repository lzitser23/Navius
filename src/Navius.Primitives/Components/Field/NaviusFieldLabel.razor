@namespace Navius.Primitives.Components.Field
@inherits FieldPart

@*
    Base UI Field.Label — a native <label for> pointing at the control id, so
    clicking the label focuses the control. Also carries a stable id so group-style
    controls (which a <label for> cannot target) can point aria-labelledby at it.
    Reflects the field's discrete state.
*@

<label id="@Field.LabelId"
       for="@Field.ControlId"
       data-navius-field-label
       @attributes="Field.MergeState(Attributes)">
    @ChildContent
</label>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Field.RegisterLabel();
    }

    public override void Dispose()
    {
        Field.UnregisterLabel();
        base.Dispose();
    }
}
