@namespace Navius.Primitives.Components.Field
@inherits FieldPart

@*
    Base UI Field.Description — a <p> of supplementary field information. Reflects
    the field's discrete state attributes and registers its id into the control's
    aria-describedby (it is always shown, so it stays active for the field's life).
*@

<p id="@_id"
   data-navius-field-description
   @attributes="Field.MergeState(Attributes)">
    @ChildContent
</p>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private readonly string _id = $"navius-field-description-{Guid.NewGuid():N}";

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Field.RegisterMessage(_id);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Reconcile aria-describedby membership after the description mounts; it is always
        // shown, so it joins immediately (the control re-renders to pick up the id).
        if (firstRender)
        {
            await Field.SetMessageActiveAsync(_id, true);
        }
    }

    public override void Dispose()
    {
        Field.UnregisterMessage(_id);
        base.Dispose();
    }
}
