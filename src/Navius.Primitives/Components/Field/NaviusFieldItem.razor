@namespace Navius.Primitives.Components.Field
@inherits FieldPart

@*
    Base UI Field.Item — a <div> grouping one item (a label + description) inside a
    checkbox/radio group. Reflects the field's discrete state attributes.
*@

<div data-navius-field-item
     @attributes="Field.MergeState(Attributes)">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
