@namespace Navius.Primitives.Components.Slider
@inherits ComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JS

@*
    Root of a slider. Owns the authoritative value ARRAY (one entry per thumb;
    controlled via @bind-Value, uncontrolled via DefaultValue) and cascades a
    SliderContext to its parts. Multiple Slider.Thumb children give a range slider.
    The keyboard model lives on each thumb (role="slider") — no JS needed for it.
    Pointer drag is the one piece that needs the DOM: the root captures the track
    host ElementReference and asks the engine's drag tracker to translate pointer
    positions into a 0..1 fraction (OnFraction below), moving whichever thumb is
    closest. data-orientation drives the layout axis; data-disabled marks the whole
    control out. A hidden <input> per value mirrors the control into native form
    submission (name/form).
*@

<CascadingValue Value="_context" IsFixed="true">
    <span @ref="_trackHost"
          data-navius-slider
          data-orientation="@Orientation"
          data-disabled="@(Disabled ? "" : null)"
          data-dragging="@(_activeThumb >= 0 ? "" : null)"
          dir="@(EffectiveDir == "rtl" ? "rtl" : null)"
          @attributes="Attributes">
        @ChildContent

        @if (!string.IsNullOrEmpty(Name))
        {
            @foreach (var v in CurrentValues)
            {
                <NaviusBubbleInput InputType="number"
                                   Name="@HiddenName"
                                   Value="@Fmt(v)"
                                   Disabled="Disabled"
                                   Form="@Form" />
            }
        }
    </span>
</CascadingValue>

@code {
    /// <summary>Controlled values (one per thumb). Provide together with <see cref="ValueChanged"/>.</summary>
    [Parameter] public IReadOnlyList<double>? Value { get; set; }

    [Parameter] public EventCallback<IReadOnlyList<double>> ValueChanged { get; set; }

    /// <summary>Initial values for uncontrolled use (one per thumb).</summary>
    [Parameter] public IReadOnlyList<double>? DefaultValue { get; set; }

    /// <summary>Fires when the value is committed (pointer up / key edit), distinct from per-change <see cref="ValueChanged"/>.</summary>
    [Parameter] public EventCallback<IReadOnlyList<double>> ValueCommitted { get; set; }

    [Parameter] public double Min { get; set; } = 0;

    [Parameter] public double Max { get; set; } = 100;

    [Parameter] public double Step { get; set; } = 1;

    /// <summary>Minimum number of steps that must separate adjacent thumbs (default 0). Prevents thumbs from crossing/overlapping.</summary>
    [Parameter] public int MinStepsBetweenThumbs { get; set; }

    /// <summary>
    /// Navius extension: explicit large step for PageUp/Down + Shift+Arrow. When 0
    /// (default), the spec heuristic is used: max(step, 10% of range snapped to step).
    /// </summary>
    [Parameter] public double LargeStep { get; set; }

    /// <summary><c>"horizontal"</c> or <c>"vertical"</c>.</summary>
    [Parameter] public string Orientation { get; set; } = "horizontal";

    /// <summary>Inverts the positional direction so high values sit at the start of the track.</summary>
    [Parameter] public bool Inverted { get; set; }

    /// <summary><c>"ltr"</c> or <c>"rtl"</c>. Falls back to the cascaded direction, then "ltr".</summary>
    [Parameter] public string? Dir { get; set; }

    [CascadingParameter(Name = "NaviusDirection")]
    public string? CascadedDir { get; set; }

    [Parameter] public bool Disabled { get; set; }

    /// <summary>Form field name. When set, a hidden number input per thumb is rendered for native submission.</summary>
    [Parameter] public string? Name { get; set; }

    /// <summary>Optional id of an associated form element (HTML form attribute).</summary>
    [Parameter] public string? Form { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private SliderContext _context = default!;
    private double[] _internal = System.Array.Empty<double>();
    private ElementReference _trackHost;
    private IJSObjectReference? _module;
    private IJSObjectReference? _dragHandle;
    private DotNetObjectReference<NaviusSlider>? _selfRef;
    private bool _engaged;
    private bool _valueWasSet;
    private int _activeThumb = -1;

    private bool IsControlled => _valueWasSet;

    /// <summary>The values currently in effect (controlled param or internal store), always sorted ascending.</summary>
    private IReadOnlyList<double> CurrentValues => IsControlled ? Sort(Value!) : _internal;

    private string EffectiveDir => Dir ?? CascadedDir ?? "ltr";

    private string? HiddenName => CurrentValues.Count > 1 ? Name + "[]" : Name;

    /// <summary>Effective large step (the spec heuristic when <see cref="LargeStep"/> is unset).</summary>
    private double EffectiveLargeStep
    {
        get
        {
            if (LargeStep > 0)
            {
                return LargeStep;
            }

            var step = Step <= 0 ? 1 : Step;
            var tenth = Math.Round((Max - Min) / 10 / step) * step;
            return Math.Max(step, tenth);
        }
    }

    public override Task SetParametersAsync(ParameterView parameters)
    {
        if (parameters.TryGetValue<IReadOnlyList<double>>(nameof(Value), out var v) && v is not null)
        {
            _valueWasSet = true;
        }

        return base.SetParametersAsync(parameters);
    }

    protected override void OnInitialized()
    {
        var seed = DefaultValue is { Count: > 0 }
            ? DefaultValue
            : (Value is { Count: > 0 } ? Value : new double[] { Min });
        _internal = SnapAll(seed);

        _context = new SliderContext(
            RequestSetThumbAsync,
            Min, Max, Step, EffectiveLargeStep, MinStepsBetweenThumbs,
            Orientation, EffectiveDir, Inverted, Disabled);
    }

    protected override async Task OnParametersSetAsync()
    {
        _context.Configure(
            Min, Max, Step, EffectiveLargeStep, MinStepsBetweenThumbs,
            Orientation, EffectiveDir, Inverted, Disabled);

        await _context.SetValuesInternalAsync(CurrentValues);
    }

    private const string ModulePath = "./_content/Navius.Primitives/navius-interop.js";
    private const string VendoredModulePath = "./navius-interop.js";

    // Package mode serves the engine under _content/Navius.Primitives/ (the RCL static web
    // assets). Vendored mode (the registry CLI) copies navius-interop.js into the app's own
    // wwwroot at the root. Try the package path first; on import failure fall back to the
    // vendored path, letting a genuine failure of that import propagate to the caller.
    private static async Task<IJSObjectReference> ImportModuleAsync(IJSRuntime js)
    {
        try
        {
            return await js.InvokeAsync<IJSObjectReference>("import", ModulePath);
        }
        catch (JSException)
        {
            return await js.InvokeAsync<IJSObjectReference>("import", VendoredModulePath);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_engaged && !Disabled)
        {
            _engaged = true;
            _selfRef ??= DotNetObjectReference.Create(this);

            try
            {
                _module ??= await ImportModuleAsync(JS);

                _dragHandle = await _module.InvokeAsync<IJSObjectReference>(
                    "createDragTracker",
                    _trackHost,
                    _selfRef,
                    new { orientation = Orientation });
            }
            catch (JSException)
            {
                // createDragTracker call failed — keyboard remains fully functional.
            }
        }
    }

    /// <summary>
    /// Invoked from the engine's drag tracker with a 0..1 visual fraction along the
    /// track. Picks the thumb closest to the pointer (on first emit of a gesture),
    /// then moves it. Honours inversion / RTL via the context.
    /// </summary>
    [JSInvokable]
    public async Task OnFraction(double fraction)
    {
        if (Disabled)
        {
            return;
        }

        var valueFraction = _context.VisualFractionToValueFraction(Math.Clamp(fraction, 0, 1));
        var span = Max - Min;
        var target = Snap(Min + span * valueFraction);

        var index = _activeThumb >= 0 ? _activeThumb : ClosestThumb(target);
        _activeThumb = index;
        await _context.SetActiveThumbAsync(index);   // data-dragging on the active thumb
        await SetThumbAsync(index, target, commit: false);
    }

    /// <summary>Invoked on pointer-up: commits the gesture (fires onValueCommit).</summary>
    [JSInvokable]
    public async Task OnCommit(double fraction)
    {
        if (Disabled)
        {
            return;
        }

        await OnFraction(fraction);
        _activeThumb = -1;
        await _context.SetActiveThumbAsync(-1);      // clear data-dragging
        StateHasChanged();                            // refresh the root's own data-dragging
        await InvokeCommitAsync();
    }

    /// <summary>Pick the thumb whose value is nearest the target (ties go to the lower index).</summary>
    private int ClosestThumb(double target)
    {
        var values = CurrentValues;
        if (values.Count == 0)
        {
            return 0;
        }

        var best = 0;
        var bestDist = Math.Abs(values[0] - target);
        for (var i = 1; i < values.Count; i++)
        {
            var d = Math.Abs(values[i] - target);
            if (d < bestDist)
            {
                bestDist = d;
                best = i;
            }
        }

        return best;
    }

    /// <summary>Snap a raw value to the nearest step from <see cref="Min"/>, then clamp to range.</summary>
    internal double Snap(double raw)
    {
        var step = Step <= 0 ? 1 : Step;
        var steps = Math.Round((raw - Min) / step, MidpointRounding.AwayFromZero);
        var snapped = Min + steps * step;
        return Math.Clamp(snapped, Min, Max);
    }

    private double[] SnapAll(IReadOnlyList<double> values)
    {
        var arr = new double[values.Count];
        for (var i = 0; i < values.Count; i++)
        {
            arr[i] = Snap(values[i]);
        }

        System.Array.Sort(arr);
        return arr;
    }

    /// <summary>Context callback: move one thumb to an absolute value (from keyboard); commits immediately.</summary>
    private Task RequestSetThumbAsync(int index, double value) => SetThumbAsync(index, value, commit: true);

    /// <summary>
    /// Move thumb <paramref name="index"/> to <paramref name="value"/>, clamped to range
    /// and to its neighbours (honouring <see cref="MinStepsBetweenThumbs"/>). Optionally
    /// fires onValueCommit afterwards (keyboard edits commit; drag commits on pointer up).
    /// </summary>
    internal async Task SetThumbAsync(int index, double value, bool commit)
    {
        if (Disabled)
        {
            return;
        }

        var current = CurrentValues;
        if (index < 0 || index >= current.Count)
        {
            return;
        }

        var step = Step <= 0 ? 1 : Step;
        var gap = MinStepsBetweenThumbs * step;

        var lower = index > 0 ? current[index - 1] + gap : Min;
        var upper = index < current.Count - 1 ? current[index + 1] - gap : Max;

        var clamped = Math.Clamp(Math.Clamp(value, Min, Max), lower, upper);

        if (clamped.Equals(current[index]))
        {
            return;
        }

        var next = current.ToArray();
        next[index] = clamped;
        // Thumbs are bounded by neighbours so they never cross; values stay sorted.

        if (IsControlled)
        {
            await ValueChanged.InvokeAsync(next);
        }
        else
        {
            _internal = next;
            await _context.SetValuesInternalAsync(next);
            StateHasChanged();
        }

        if (commit)
        {
            await InvokeCommitAsync();
        }
    }

    private async Task InvokeCommitAsync()
    {
        if (ValueCommitted.HasDelegate)
        {
            await ValueCommitted.InvokeAsync(CurrentValues.ToArray());
        }
    }

    private static double[] Sort(IReadOnlyList<double> values)
    {
        var arr = values.ToArray();
        System.Array.Sort(arr);
        return arr;
    }

    private static string Fmt(double v) => v.ToString(System.Globalization.CultureInfo.InvariantCulture);

    public async ValueTask DisposeAsync()
    {
        if (_dragHandle is not null)
        {
            try
            {
                await _dragHandle.InvokeVoidAsync("destroy");
                await _dragHandle.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
            catch (JSException) { }
            _dragHandle = null;
        }

        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }

        _selfRef?.Dispose();
    }
}
