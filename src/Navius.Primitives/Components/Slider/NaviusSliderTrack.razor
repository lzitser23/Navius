@namespace Navius.Primitives.Components.Slider
@inherits SliderPart

@*
    The track — the full-length rail the range fills and the thumb travels along.
    Pure layout: it carries the orientation/disabled data-* so consumers can size
    it (e.g. h-1.5 w-full horizontally, w-1.5 h-full vertically). It holds the
    NaviusSliderRange. No interaction lives here; pointer drag is handled on the
    root's host element by the engine.
*@

<span data-navius-slider-track
      data-orientation="@Context.Orientation"
      data-disabled="@(Context.Disabled ? "" : null)"
      @attributes="Attributes">
    @ChildContent
</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
