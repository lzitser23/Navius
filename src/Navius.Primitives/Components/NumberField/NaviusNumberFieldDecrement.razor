@namespace Navius.Primitives.Components.NumberField
@inherits NumberFieldPart

@*
    Base UI NumberField.Decrement — a stepper button that subtracts Step from the
    value. Out of the tab order (the input is the focus target); disabled at Min.
*@

<button type="button"
        tabindex="-1"
        aria-label="Decrease"
        disabled="@IsDisabled"
        data-navius-number-field-decrement
        data-disabled="@(IsDisabled ? "" : null)"
        @onclick="OnClickAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private bool IsDisabled => Context.Disabled || !Context.CanDecrement;

    private Task OnClickAsync() => Context.StepAsync(-Context.Step);
}
