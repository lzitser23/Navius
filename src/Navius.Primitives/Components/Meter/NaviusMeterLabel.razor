@namespace Navius.Primitives.Components.Meter

@* Base UI Meter.Label — an accessible label; the Root wires aria-labelledby to it. *@
<span id="@Context.LabelId" data-navius-meter-label @attributes="Attributes">@ChildContent</span>

@code {
    [CascadingParameter] private MeterContext Context { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    protected override void OnInitialized() => Context.SetHasLabel();
}
