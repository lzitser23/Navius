@namespace Navius.Primitives.Components.ContextMenu
@inherits ComponentBase
@implements IDisposable

@*
    role="menuitemradio". aria-checked / data-state reflect whether this item's
    Value matches the parent RadioGroup's selected value. Selecting sets the group
    value and fires OnSelect; the menu closes unless the consumer calls
    PreventDefault(). Hosts a NaviusContextMenuItemIndicator that mounts only while
    selected. Mirrors the spec ContextMenu.RadioItem.
*@

<CascadingValue Value="_checkable" IsFixed="true">
    <div role="menuitemradio"
         tabindex="-1"
         data-navius-context-menu-radio-item
         aria-checked="@(IsChecked ? "true" : "false")"
         data-checked="@(IsChecked ? "" : null)"
         data-unchecked="@(IsChecked ? null : "")"
         data-disabled="@(Disabled ? "" : null)"
         aria-disabled="@(Disabled ? "true" : null)"
         data-navius-text-value="@TextValue"
         @onclick="ActivateAsync"
         @onkeydown="OnKeyDownAsync"
         @onkeydown:preventDefault="_preventKeyDefault"
         @attributes="Attributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [CascadingParameter] private ContextMenuContext Context { get; set; } = default!;

    [CascadingParameter] private ContextMenuRadioGroupContext Group { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>This item's value within the radio group (required).</summary>
    [Parameter] public string Value { get; set; } = default!;

    /// <summary>Cancelable select. PreventDefault() keeps the menu open after selecting.</summary>
    [Parameter] public EventCallback<NaviusSelectEventArgs> OnSelect { get; set; }

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public string? TextValue { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private readonly ContextMenuCheckableContext _checkable = new();
    private Action? _onGroupChange;
    private bool _preventKeyDefault;

    private bool IsChecked => Group.IsSelected(Value);

    protected override void OnInitialized()
    {
        _onGroupChange = () =>
        {
            _checkable.SetChecked(IsChecked);
            InvokeAsync(StateHasChanged);
        };
        Group.Changed += _onGroupChange;
    }

    protected override void OnParametersSet()
    {
        _checkable.SetChecked(IsChecked);
    }

    private async Task ActivateAsync()
    {
        if (Disabled)
        {
            return;
        }

        await Group.RequestSelectAsync(Value);

        var args = new NaviusSelectEventArgs();
        if (OnSelect.HasDelegate)
        {
            await OnSelect.InvokeAsync(args);
        }

        if (!args.DefaultPrevented)
        {
            await Context.RequestCloseAsync();
        }
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        _preventKeyDefault = e.Key == " ";

        if (e.Key == "Enter" || e.Key == " ")
        {
            await ActivateAsync();
        }
    }

    public void Dispose()
    {
        if (_onGroupChange is not null)
        {
            Group.Changed -= _onGroupChange;
        }
    }
}
