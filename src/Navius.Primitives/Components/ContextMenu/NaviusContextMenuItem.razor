@namespace Navius.Primitives.Components.ContextMenu

@*
    A menu item. role="menuitem", tabindex="-1" so Tab skips it and roving focus
    (arrows) moves between items. Activates on click or Enter/Space, then closes
    the menu — unless the consumer calls PreventDefault() on the select args, in
    which case the menu stays open (parity with the spec onSelect). Disabled items are
    skipped by roving focus (data-disabled) and don't activate. Space is
    prevent-defaulted at the item level so the page never scrolls on activation.

    TextValue overrides the type-ahead match text for icon/complex content
    (emitted as data-navius-text-value, which the engine prefers over textContent).
*@

<div role="menuitem"
     tabindex="-1"
     data-navius-context-menu-item
     data-disabled="@(Disabled ? "" : null)"
     aria-disabled="@(Disabled ? "true" : null)"
     data-navius-text-value="@TextValue"
     @onclick="ActivateAsync"
     @onkeydown="OnKeyDownAsync"
     @onkeydown:preventDefault="_preventKeyDefault"
     @attributes="Attributes">
    @ChildContent
</div>

@code {
    [CascadingParameter] private ContextMenuContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Invoked when the item is chosen (click or Enter/Space). Call
    /// <c>args.PreventDefault()</c> to keep the menu open after selection.
    /// </summary>
    [Parameter] public EventCallback<NaviusSelectEventArgs> OnSelect { get; set; }

    [Parameter] public bool Disabled { get; set; }

    /// <summary>Overrides the type-ahead match text (for icon/complex content).</summary>
    [Parameter] public string? TextValue { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    // Set true only for the duration of a Space keydown so @onkeydown:preventDefault
    // suppresses page scroll without blocking other keys (arrows/type-ahead).
    private bool _preventKeyDefault;

    private async Task ActivateAsync()
    {
        if (Disabled)
        {
            return;
        }

        var args = new NaviusSelectEventArgs();
        if (OnSelect.HasDelegate)
        {
            await OnSelect.InvokeAsync(args);
        }

        if (!args.DefaultPrevented)
        {
            await Context.RequestCloseAsync();
        }
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        _preventKeyDefault = e.Key == " ";

        if (e.Key == "Enter" || e.Key == " ")
        {
            await ActivateAsync();
        }
    }
}
