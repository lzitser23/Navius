@namespace Navius.Primitives.Components.ContextMenu
@implements IDisposable

@* role="group" wrapper. A Label child registers its id and the group references it
   via aria-labelledby (SR grouping). Mirrors the spec ContextMenu.Group. *@

<CascadingValue Value="_group" IsFixed="true">
    <div role="group"
         aria-labelledby="@_group.LabelId"
         data-navius-context-menu-group
         @attributes="Attributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private readonly ContextMenuGroupContext _group = new();
    private Action? _onChange;

    protected override void OnInitialized()
    {
        _onChange = () => InvokeAsync(StateHasChanged);
        _group.Changed += _onChange;
    }

    public void Dispose()
    {
        if (_onChange is not null)
        {
            _group.Changed -= _onChange;
        }
    }
}
