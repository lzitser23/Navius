@namespace Navius.Primitives.Components.ContextMenu
@inherits ComponentBase
@implements IDisposable

@*
    role="group" holding a set of RadioItems. Controlled via @bind-Value (string);
    uncontrolled via DefaultValue. Control mode is detected by whether Value was
    explicitly supplied, NOT by whether the change callback is attached. Mirrors
    the spec ContextMenu.RadioGroup.
*@

<CascadingValue Value="_group" IsFixed="true">
    <div role="group"
         data-navius-context-menu-radio-group
         @attributes="Attributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Controlled selected value. Use @@bind-Value.</summary>
    [Parameter] public string? Value { get; set; }

    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>Uncontrolled initial selected value.</summary>
    [Parameter] public string? DefaultValue { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private ContextMenuRadioGroupContext _group = default!;
    private string? _internalValue;
    private bool _initialized;
    private bool _valueSet;
    private Action? _onChange;

    private bool IsControlled => _valueSet;

    private string? CurrentValue => IsControlled ? Value : _internalValue;

    public override Task SetParametersAsync(ParameterView parameters)
    {
        _valueSet = false;
        foreach (var p in parameters)
        {
            if (p.Name == nameof(Value))
            {
                _valueSet = true;
            }
        }

        return base.SetParametersAsync(parameters);
    }

    protected override void OnInitialized()
    {
        _group = new ContextMenuRadioGroupContext(RequestSelectAsync);
        _onChange = () => InvokeAsync(StateHasChanged);
        _group.Changed += _onChange;
    }

    protected override void OnParametersSet()
    {
        if (!_initialized)
        {
            _internalValue = DefaultValue;
            _initialized = true;
        }

        _group.SetValue(CurrentValue);
    }

    private async Task RequestSelectAsync(string value)
    {
        if (IsControlled)
        {
            await ValueChanged.InvokeAsync(value);
        }
        else
        {
            _internalValue = value;
            await ValueChanged.InvokeAsync(value);
            _group.SetValue(value);
        }
    }

    public void Dispose()
    {
        if (_onChange is not null)
        {
            _group.Changed -= _onChange;
        }
    }
}
