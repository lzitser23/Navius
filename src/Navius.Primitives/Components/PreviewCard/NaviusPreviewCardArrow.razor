@namespace Navius.Primitives.Components.PreviewCard
@inherits PreviewCardPart
@implements IAsyncDisposable

@*
    The spec PreviewCard.Arrow. An SVG triangle rendered inside the popup that the
    positioner keeps pointing at the trigger; the engine writes data-side on it.
    Registers its element with the context so the popup passes it to the engine's arrow
    middleware. Place INSIDE NaviusPreviewCardPopup.
*@

<svg @ref="_element"
     width="@Width"
     height="@Height"
     viewBox="0 0 30 10"
     preserveAspectRatio="none"
     aria-hidden="true"
     data-navius-preview-card-arrow
     @attributes="Attributes">
    <polygon points="0,0 30,0 15,10" />
</svg>

@code {
    private ElementReference _element;
    private bool _registered;

    /// <summary>Arrow width in pixels. the spec default 10.</summary>
    [Parameter] public double Width { get; set; } = 10;

    /// <summary>Arrow height in pixels. the spec default 5.</summary>
    [Parameter] public double Height { get; set; } = 5;

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_registered)
        {
            _registered = true;
            await Context.RegisterArrowAsync(_element);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_registered)
        {
            await Context.UnregisterArrowAsync();
        }
    }
}
