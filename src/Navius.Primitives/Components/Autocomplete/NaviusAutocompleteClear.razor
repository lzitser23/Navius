@namespace Navius.Primitives.Components.Autocomplete
@inherits AutocompletePart

@*
    The Base UI Autocomplete.Clear — clears the query (which is the value) and returns
    focus to the input. tabindex=-1 so it stays out of the Tab order.
*@

<button type="button"
        tabindex="-1"
        data-navius-autocomplete-clear
        @onclick="OnClickAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private async Task OnClickAsync()
    {
        await Context.SetQueryAsync("");
        if (Context.HasTrigger)
        {
            try { await Context.TriggerElement.FocusAsync(); } catch { /* input may be gone */ }
        }
    }
}
