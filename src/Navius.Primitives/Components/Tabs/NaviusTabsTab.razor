@namespace Navius.Primitives.Components.Tabs
@implements IDisposable

@*
    role=tab (Base UI Tabs.Tab). Roving tabindex: only the active tab stop is in the Tab
    order (tabindex=0); the rest are -1 and reached by arrow keys. data-active marks the
    selected tab (presence; no data-state); data-activation-direction mirrors the root.
*@

<button @ref="_element"
        type="button"
        role="tab"
        id="@Context.TriggerId(Value)"
        aria-selected="@(IsSelected ? "true" : "false")"
        aria-controls="@Context.PanelId(Value)"
        tabindex="@(IsTabStop ? 0 : -1)"
        disabled="@Disabled"
        data-active="@(IsSelected ? "" : null)"
        data-orientation="@Context.Orientation"
        data-activation-direction="@Context.ActivationDirection"
        data-disabled="@(Disabled ? "" : null)"
        data-navius-tabs-tab
        @onclick="OnClickAsync"
        @onkeydown="OnKeyDownAsync"
        @onfocus="OnFocus"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    [CascadingParameter] private TabsContext Context { get; set; } = default!;

    [Parameter] public string Value { get; set; } = "";

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private ElementReference _element;
    private Func<Task>? _onChange;

    private bool IsSelected => Context.Selected == Value;

    private bool IsTabStop => Context.TabStopValue is { } v ? v == Value : IsSelected;

    protected override void OnInitialized()
    {
        _onChange = () => InvokeAsync(StateHasChanged);
        Context.Changed += _onChange;
        Context.Register(Value, () => _element, () => Disabled);
    }

    private async Task OnClickAsync()
    {
        if (Disabled)
        {
            return;
        }

        await Context.SelectAsync(Value);
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        if (Disabled)
        {
            return;
        }

        // Manual activation: Enter/Space selects the focused tab. (In automatic mode arrow
        // keys already activated it, so this is a harmless re-select.)
        if (e.Key == "Enter" || e.Key == " " || e.Key == "Spacebar")
        {
            await Context.SelectAsync(Value);
        }
    }

    private void OnFocus()
    {
        // Track focus so the roving tab stop can follow it in manual activation mode.
        Context.NotifyFocused(Value);
    }

    public void Dispose()
    {
        if (_onChange is not null)
        {
            Context.Changed -= _onChange;
        }

        Context.Unregister(Value);
    }
}
