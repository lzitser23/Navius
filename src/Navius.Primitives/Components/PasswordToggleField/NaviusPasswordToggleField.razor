@namespace Navius.Primitives.Components.PasswordToggleField
@inherits ComponentBase

@* Root of the password toggle field. Owns visibility state, cascades the context. Renders no DOM. *@

<CascadingValue Value="_context" IsFixed="true">
    @ChildContent
</CascadingValue>

@code {
    private PasswordToggleFieldContext _context = default!;
    private bool _internalVisible;

    /// <summary>Controlled revealed state. Pair with <see cref="VisibleChanged"/>.</summary>
    [Parameter] public bool Visible { get; set; }

    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }

    /// <summary>Uncontrolled initial revealed state.</summary>
    [Parameter] public bool DefaultVisible { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool IsControlled => VisibleChanged.HasDelegate;

    protected override void OnInitialized()
    {
        _internalVisible = DefaultVisible;
        _context = new PasswordToggleFieldContext(RequestSetAsync);
    }

    protected override async Task OnParametersSetAsync()
    {
        var authoritative = IsControlled ? Visible : _internalVisible;
        await _context.SetVisibleInternalAsync(authoritative);
    }

    private async Task RequestSetAsync(bool value)
    {
        if (IsControlled)
        {
            await VisibleChanged.InvokeAsync(value);
        }
        else
        {
            _internalVisible = value;
            await _context.SetVisibleInternalAsync(value);
            StateHasChanged();
        }
    }
}
