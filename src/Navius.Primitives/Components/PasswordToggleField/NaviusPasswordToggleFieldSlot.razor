@namespace Navius.Primitives.Components.PasswordToggleField
@inherits PasswordToggleFieldPart

@* Swaps arbitrary content based on the revealed state — mirrors the spec
   PasswordToggleField.Slot, which renders its `visible` content while the
   password is shown and its `hidden` content while it is concealed.

   the spec's `render` function prop (full custom per-state output) maps to the
   optional Render RenderFragment<bool> here, which receives the current visible
   state. When Render is supplied it takes precedence over Visible / Hidden.
   Re-renders automatically when the state flips (the Part base subscribes to the
   context). *@

@if (Render is not null)
{
    @Render(Context.Visible)
}
else
{
    @(Context.Visible ? Visible : Hidden)
}

@code {
    /// <summary>Content shown while the password is revealed (type="text").</summary>
    [Parameter] public RenderFragment? Visible { get; set; }

    /// <summary>Content shown while the password is hidden (type="password").</summary>
    [Parameter] public RenderFragment? Hidden { get; set; }

    /// <summary>
    /// Fully custom per-state content (maps to the spec's <c>render</c> prop). Receives the
    /// current visible state. Takes precedence over <see cref="Visible"/> / <see cref="Hidden"/>.
    /// </summary>
    [Parameter] public RenderFragment<bool>? Render { get; set; }
}
