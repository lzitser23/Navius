@namespace Navius.Primitives.Components.PasswordToggleField
@inherits PasswordToggleFieldPart

@* Renders one of two icons depending on the revealed state — mirrors the spec
   PasswordToggleField.Icon, whose required `visible` / `hidden` props supply the
   icon shown when the password is revealed vs hidden. Re-renders automatically
   when the state flips (the Part base subscribes to the context).

   Typically nested inside NaviusPasswordToggleFieldToggle to give an icon-only
   control its glyph; the Toggle still carries the flipping accessible name. *@

@(Context.Visible ? Visible : Hidden)

@code {
    /// <summary>Content shown while the password is revealed (type="text").</summary>
    [Parameter] public RenderFragment? Visible { get; set; }

    /// <summary>Content shown while the password is hidden (type="password").</summary>
    [Parameter] public RenderFragment? Hidden { get; set; }
}
