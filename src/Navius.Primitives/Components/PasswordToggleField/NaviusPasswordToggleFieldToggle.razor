@namespace Navius.Primitives.Components.PasswordToggleField
@implements IAsyncDisposable
@inherits PasswordToggleFieldPart
@inject IJSRuntime JS

@* Button that reveals / hides the password. State is conveyed only through a
   flipping accessible name (Show / Hide password) — mirroring the spec, which
   deliberately omits aria-pressed and data-state here so screen readers don't
   double-announce the state. Mirrors the spec: pointer activation returns focus to
   the input, keyboard/virtual activation keeps focus on the button. *@

<button type="button"
        aria-label="@(Context.Visible ? "Hide password" : "Show password")"
        aria-controls="@Context.InputId"
        data-navius-password-toggle-field-toggle
        @onclick="ToggleAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    private const string ModulePath = "./_content/Navius.Primitives/navius-interop.js";
    private const string VendoredModulePath = "./navius-interop.js";

    // Package mode serves the engine under _content/Navius.Primitives/ (the RCL static web
    // assets). Vendored mode (the registry CLI) copies navius-interop.js into the app's own
    // wwwroot at the root. Try the package path first; on import failure fall back to the
    // vendored path, letting a genuine failure of that import propagate to the caller.
    private static async Task<IJSObjectReference> ImportModuleAsync(IJSRuntime js)
    {
        try
        {
            return await js.InvokeAsync<IJSObjectReference>("import", ModulePath);
        }
        catch (JSException)
        {
            return await js.InvokeAsync<IJSObjectReference>("import", VendoredModulePath);
        }
    }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    private IJSObjectReference? _module;

    private async Task ToggleAsync(MouseEventArgs args)
    {
        await Context.RequestToggleAsync();

        // detail > 0 => a real pointer click; the spec returns focus to the input.
        // detail == 0 => activated via keyboard (Enter/Space) or virtual/assistive
        // navigation, where focus stays on the toggle button.
        if (args.Detail <= 0)
        {
            return;
        }

        // Best-effort: import the engine module directly and call its `focusElementById`
        // export to return focus to the input. If the call fails, focus stays put.
        try
        {
            _module ??= await ImportModuleAsync(JS);
            await _module.InvokeVoidAsync("focusElementById", Context.InputId);
        }
        catch (JSException)
        {
            // Engine call failed — keyboard fallback already kept focus reasonable.
        }
    }

    public async ValueTask DisposeAsync()
    {
        Dispose();
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit already gone — nothing to release.
            }
        }
    }
}
