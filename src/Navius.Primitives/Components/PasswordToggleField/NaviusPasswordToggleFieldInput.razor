@namespace Navius.Primitives.Components.PasswordToggleField
@implements IAsyncDisposable
@inherits PasswordToggleFieldPart
@inject IJSRuntime JS

@* The password input. Switches between type="password" and type="text" as the
   revealed state changes. value / oninput etc. are forwarded by the consumer
   through @attributes.

   Security behaviour (mirrors the spec): the input subscribes to its enclosing
   <form>'s submit and reset events and forces the field back to hidden, so a
   revealed password is never persisted across a submit/reset.

   autocomplete defaults to "current-password" (the spec's default) but the consumer
   can override it through @attributes — the splat is rendered after the literal,
   so a supplied autocomplete wins. *@

<input @ref="_element"
       id="@Context.InputId"
       type="@(Context.Visible ? "text" : "password")"
       autocomplete="current-password"
       data-navius-password-toggle-field-input
       @attributes="Attributes" />

@code {
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    private ElementReference _element;
    private NaviusJsInterop? _interop;
    private FormResetSubmitListener? _listener;
    private DotNetObjectReference<NaviusPasswordToggleFieldInput>? _selfRef;
    private bool _engaged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _engaged)
        {
            return;
        }

        _engaged = true;
        _selfRef ??= DotNetObjectReference.Create(this);
        _interop ??= new NaviusJsInterop(JS);

        try
        {
            _listener = await _interop.CreateFormResetSubmitListenerAsync(_element, _selfRef);
        }
        catch (JSException)
        {
            // Listener not available — visibility toggling still works; only the
            // submit/reset auto-hide is skipped.
        }
    }

    /// <summary>The enclosing form is submitting — hide the password again.</summary>
    [JSInvokable]
    public Task OnFormSubmit() => Context.RequestSetAsync(false);

    /// <summary>The enclosing form is resetting — hide the password again.</summary>
    [JSInvokable]
    public Task OnFormReset() => Context.RequestSetAsync(false);

    public async ValueTask DisposeAsync()
    {
        Dispose();

        if (_listener is not null)
        {
            await _listener.DisposeAsync();
            _listener = null;
        }

        if (_interop is not null)
        {
            await _interop.DisposeAsync();
            _interop = null;
        }

        _selfRef?.Dispose();
    }
}
