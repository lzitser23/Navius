@namespace Navius.Primitives.Components.Select

@*
    the spec Select.Icon — the chevron affordance inside the Trigger. aria-hidden
    (decorative). Renders a default chevron-down SVG when no ChildContent is given,
    overridable by passing your own icon.
*@

<span aria-hidden="true" data-navius-select-icon @attributes="Attributes">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4.18179 6.18181C4.35753 6.00608 4.64245 6.00608 4.81819 6.18181L7.49999 8.86362L10.1818 6.18181C10.3575 6.00608 10.6424 6.00608 10.8182 6.18181C10.9939 6.35755 10.9939 6.64247 10.8182 6.81821L7.81819 9.81821C7.64245 9.99395 7.35753 9.99395 7.18179 9.81821L4.18179 6.81821C4.00605 6.64247 4.00605 6.35755 4.18179 6.18181Z"
                  fill="currentColor" fill-rule="evenodd" clip-rule="evenodd" />
        </svg>
    }
</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
