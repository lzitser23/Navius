@namespace Navius.Primitives.Components.Select
@implements IDisposable

@*
    the spec Select.ScrollUpButton — mounts only when the Viewport is scrolled down
    from the top (there is content above the fold). aria-hidden (decorative;
    keyboard users scroll via item navigation). Continuous auto-scroll while the
    pointer hovers requires an engine viewport-scroll helper (see engineGaps);
    visibility tracking is fully wired here via the SelectViewportContext.
*@

@if (Viewport is not null && Viewport.CanScrollUp)
{
    <div aria-hidden="true"
         data-navius-select-scroll-up-button
         @attributes="Attributes">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3.13523 8.84197C3.3241 9.04343 3.64052 9.05363 3.84197 8.86477L7.5 5.43536L11.158 8.86477C11.3595 9.05363 11.6759 9.04343 11.8648 8.84197C12.0536 8.64051 12.0434 8.32409 11.842 8.13523L7.84197 4.38523C7.64964 4.20492 7.35036 4.20492 7.15803 4.38523L3.15803 8.13523C2.95657 8.32409 2.94637 8.64051 3.13523 8.84197Z"
                      fill="currentColor" fill-rule="evenodd" clip-rule="evenodd" />
            </svg>
        }
    </div>
}

@code {
    [CascadingParameter] private SelectViewportContext? Viewport { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private Action? _onChange;

    protected override void OnInitialized()
    {
        if (Viewport is not null)
        {
            _onChange = () => InvokeAsync(StateHasChanged);
            Viewport.Changed += _onChange;
        }
    }

    public void Dispose()
    {
        if (Viewport is not null && _onChange is not null) Viewport.Changed -= _onChange;
    }
}
