@namespace Navius.Primitives.Components.Select

@*
    the spec Select.Group — role=group wrapping a set of related items, labelled by a
    child NaviusSelectLabel via aria-labelledby. The group is not focusable; only
    its [role=option] items are roving-focusable.
*@

<CascadingValue Value="_group" IsFixed="true">
    <div role="group"
         aria-labelledby="@_group.LabelId"
         data-navius-select-group
         @attributes="Attributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private readonly SelectGroupContext _group = new();

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
