@namespace Navius.Primitives.Components.Select
@implements IAsyncDisposable
@inject IJSRuntime JS

@*
    the spec Select.Viewport — the scrollable container wrapping the items/groups/
    separators inside the Content. The consumer gives it overflow + a bounded
    max-height; native overflow then scrolls (wheel, keyboard, trackpad) for free.

    It observes its own scroll geometry via the engine's observeScrollArea and
    publishes CanScrollUp/CanScrollDown on a SelectViewportContext so the
    ScrollUp/ScrollDown buttons mount only when there's content to reveal in that
    direction.
*@

<CascadingValue Value="_viewport" IsFixed="true">
    <div @ref="_element"
         role="presentation"
         data-navius-select-viewport
         @attributes="Attributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private const string ModulePath = "./_content/Navius.Primitives/navius-interop.js";
    private const string VendoredModulePath = "./navius-interop.js";

    // Package mode serves the engine under _content/Navius.Primitives/ (the RCL static web
    // assets). Vendored mode (the registry CLI) copies navius-interop.js into the app's own
    // wwwroot at the root. Try the package path first; on import failure fall back to the
    // vendored path, letting a genuine failure of that import propagate to the caller.
    private static async Task<IJSObjectReference> ImportModuleAsync(IJSRuntime js)
    {
        try
        {
            return await js.InvokeAsync<IJSObjectReference>("import", ModulePath);
        }
        catch (JSException)
        {
            return await js.InvokeAsync<IJSObjectReference>("import", VendoredModulePath);
        }
    }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private readonly SelectViewportContext _viewport = new();
    private ElementReference _element;
    private DotNetObjectReference<NaviusSelectViewport>? _selfRef;
    private IJSObjectReference? _module;
    private IJSObjectReference? _observer;
    private Action? _onChange;
    private bool _engaged;

    protected override void OnInitialized()
    {
        _onChange = () => InvokeAsync(StateHasChanged);
        _viewport.Changed += _onChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _engaged) return;

        _engaged = true;
        _viewport.Element = _element;
        _viewport.HasElement = true;
        _selfRef = DotNetObjectReference.Create(this);

        try
        {
            _module = await ImportModuleAsync(JS);
            _observer = await _module.InvokeAsync<IJSObjectReference>(
                "observeScrollArea", _element, _selfRef);
        }
        catch (JSException)
        {
            // Observer not available — native overflow still scrolls; the buttons
            // simply won't auto-reveal until metrics arrive.
        }
    }

    /// <summary>Invoked by the engine on every scroll/resize with fresh viewport metrics.</summary>
    [JSInvokable]
    public Task OnScrollMetrics(ScrollMetrics m)
    {
        _viewport.UpdateScrollState(m.ScrollTop, m.ScrollHeight, m.ClientHeight);
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnScrollActivity() => Task.CompletedTask;

    public sealed record ScrollMetrics(
        double ScrollTop,
        double ScrollHeight,
        double ClientHeight,
        double ScrollLeft,
        double ScrollWidth,
        double ClientWidth);

    public async ValueTask DisposeAsync()
    {
        if (_onChange is not null) _viewport.Changed -= _onChange;

        if (_observer is not null)
        {
            try
            {
                await _observer.InvokeVoidAsync("destroy");
                await _observer.DisposeAsync();
            }
            catch (JSException) { }
            catch (JSDisconnectedException) { }
        }

        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }

        _selfRef?.Dispose();
    }
}
