@namespace Navius.Primitives.Components.Menu
@inherits ComponentBase

@*
    the spec Sub: owns its OWN nested open state and cascades a sub-context to its
    SubTrigger / SubContent. Controlled via @bind-Open, uncontrolled via DefaultOpen.
    Renders no DOM of its own.
*@

<CascadingValue Value="_subContext" IsFixed="true">
    @ChildContent
</CascadingValue>

@code {
    private MenuSubContext _subContext = default!;
    private bool _internalOpen;

    [Parameter] public bool Open { get; set; }

    [Parameter] public EventCallback<bool> OpenChanged { get; set; }

    [Parameter] public bool DefaultOpen { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    // Controlled-ness is determined by whether Open was explicitly supplied (tracked in
    // SetParametersAsync), NOT by OpenChanged.HasDelegate.
    private bool _openSet;
    private bool IsControlled => _openSet;

    public override Task SetParametersAsync(ParameterView parameters)
    {
        if (parameters.TryGetValue<bool>(nameof(Open), out _))
        {
            _openSet = true;
        }

        return base.SetParametersAsync(parameters);
    }

    protected override void OnInitialized()
    {
        _internalOpen = DefaultOpen;
        _subContext = new MenuSubContext(RequestSetAsync);
    }

    protected override async Task OnParametersSetAsync()
    {
        await _subContext.SetOpenInternalAsync(IsControlled ? Open : _internalOpen);
    }

    private async Task RequestSetAsync(bool value)
    {
        if (IsControlled)
        {
            await OpenChanged.InvokeAsync(value);
        }
        else
        {
            _internalOpen = value;
            await _subContext.SetOpenInternalAsync(value);
            if (OpenChanged.HasDelegate)
            {
                // Surface the change to observers even when uncontrolled (the spec's onOpenChange).
                await OpenChanged.InvokeAsync(value);
            }
            StateHasChanged();
        }
    }
}
