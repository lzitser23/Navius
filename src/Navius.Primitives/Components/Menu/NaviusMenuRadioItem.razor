@namespace Navius.Primitives.Components.Menu
@implements IDisposable

@*
    role="menuitemradio" item inside a RadioGroup. Its checked state is derived from
    whether the group's value equals this item's Value. On select it asks the group to
    select its value, fires OnSelect (cancelable), and closes the menu unless prevented.
    Cascades an item-state context the ItemIndicator reads.
*@

<div role="menuitemradio"
     tabindex="-1"
     data-navius-menu-item
     data-navius-menu-radio-item
     aria-checked="@(IsChecked ? "true" : "false")"
     data-checked="@(IsChecked ? "" : null)"
     data-unchecked="@(IsChecked ? null : "")"
     data-disabled="@(Disabled ? "" : null)"
     aria-disabled="@(Disabled ? "true" : null)"
     data-navius-text-value="@TextValue"
     @onclick="ActivateAsync"
     @onkeydown="OnKeyDownAsync"
     @attributes="Attributes">
    <CascadingValue Value="_stateContext" IsFixed="true">
        @ChildContent
    </CascadingValue>
</div>

@code {
    [CascadingParameter] private MenuContext Context { get; set; } = default!;
    [CascadingParameter] private MenuRadioContext RadioContext { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>This item's value; selected when it equals the group's value.</summary>
    [Parameter] public string Value { get; set; } = default!;

    /// <summary>Cancelable select. PreventDefault() keeps the menu open after selecting.</summary>
    [Parameter] public EventCallback<NaviusSelectEventArgs> OnSelect { get; set; }

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public string? TextValue { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private readonly MenuItemStateContext _stateContext = new();
    private Action? _onChange;

    private bool IsChecked => RadioContext.Value == Value;

    protected override void OnInitialized()
    {
        _onChange = () =>
        {
            SyncState();
            _ = InvokeAsync(StateHasChanged);
        };
        RadioContext.Changed += _onChange;
    }

    protected override void OnParametersSet() => SyncState();

    private void SyncState()
    {
        if (_stateContext.Checked != IsChecked)
        {
            _stateContext.Checked = IsChecked;
            _stateContext.NotifyChanged();
        }
    }

    private async Task ActivateAsync()
    {
        if (Disabled)
        {
            return;
        }

        await RadioContext.SelectAsync(Value);

        var args = new NaviusSelectEventArgs();
        if (OnSelect.HasDelegate)
        {
            await OnSelect.InvokeAsync(args);
        }

        if (!args.DefaultPrevented)
        {
            await Context.RequestCloseAsync();
        }
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == " ")
        {
            await ActivateAsync();
        }
    }

    public void Dispose()
    {
        if (_onChange is not null)
        {
            RadioContext.Changed -= _onChange;
        }
    }
}
