@namespace Navius.Primitives.Components.Menu
@inherits MenuPart

@* Toggles the menu; ArrowUp/Down opens it (then the content focuses the first item). *@

<button type="button"
        @ref="_element"
        aria-haspopup="menu"
        aria-expanded="@(Context.Open ? "true" : "false")"
        aria-controls="@Context.ContentId"
        data-popup-open="@(Context.Open ? "" : null)"
        data-disabled="@(Disabled ? "" : null)"
        disabled="@Disabled"
        data-navius-menu-trigger
        @onclick="OnClickAsync"
        @onkeydown="OnKeyDownAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    private ElementReference _element;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>When true the trigger is non-interactive and reflects data-disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Context.TriggerElement = _element;
            Context.HasTrigger = true;
        }
    }

    private async Task OnClickAsync()
    {
        if (Disabled)
        {
            return;
        }

        await Context.RequestToggleAsync();
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        if (Disabled)
        {
            return;
        }

        if ((e.Key == "ArrowDown" || e.Key == "ArrowUp" || e.Key == "Enter" || e.Key == " ") && !Context.Open)
        {
            await Context.RequestSetAsync(true);
        }
    }
}
