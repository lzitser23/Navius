@namespace Navius.Primitives.Components.Menu

@*
    A group heading. Not roving-focusable (no role=menuitem). Generates an id and,
    when nested in a Group, registers it so the Group's aria-labelledby points here.
*@

<div id="@_id" data-navius-menu-group-label @attributes="Attributes">@ChildContent</div>

@code {
    [CascadingParameter] private MenuGroupContext? GroupContext { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private readonly string _id = $"navius-menu-label-{Guid.NewGuid():N}";

    protected override void OnInitialized()
    {
        GroupContext?.SetLabelId(_id);
    }
}
