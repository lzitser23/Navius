@namespace Navius.Primitives.Components.Fieldset
@inherits ComponentBase
@implements IDisposable

@*
    Base UI Fieldset.Legend — rendered as a <div> (NOT a native <legend>) for
    positioning freedom, associated as the fieldset's label via aria-labelledby on
    the root (this legend carries the referenced id). Reflects the fieldset's
    disabled state via data-disabled.
*@

<div id="@Context?.LegendId"
     data-navius-fieldset-legend
     data-disabled="@(Context?.Disabled == true ? "" : null)"
     @attributes="Attributes">
    @ChildContent
</div>

@code {
    [CascadingParameter] private FieldsetContext? Context { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    protected override void OnInitialized() => Context?.RegisterLegend();

    public void Dispose() => Context?.UnregisterLegend();
}
