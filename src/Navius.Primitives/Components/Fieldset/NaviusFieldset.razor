@namespace Navius.Primitives.Components.Fieldset
@inherits ComponentBase

@*
    Base UI Fieldset.Root — a native <fieldset> grouping related fields under a
    shared legend. When Disabled, the native fieldset disables every contained
    control for free, and a FieldsetContext cascades the disabled state so the
    legend and contained NaviusFields reflect data-disabled. Emits discrete
    data-disabled (never data-state).
*@

<CascadingValue Value="_context" IsFixed="false">
    <fieldset data-navius-fieldset
              disabled="@Disabled"
              data-disabled="@(Disabled ? "" : null)"
              @attributes="Attributes">
        @ChildContent
    </fieldset>
</CascadingValue>

@code {
    /// <summary>Disables the fieldset and everything inside it.</summary>
    [Parameter] public bool Disabled { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private FieldsetContext _context = new();

    protected override void OnParametersSet()
    {
        if (_context.Disabled != Disabled)
        {
            _context = new FieldsetContext { Disabled = Disabled };
        }
    }
}
