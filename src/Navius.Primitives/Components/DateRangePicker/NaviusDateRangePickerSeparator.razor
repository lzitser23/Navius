@namespace Navius.Primitives.Components.DateRangePicker
@inherits ComponentBase

@* The visual "to" separator between the two endpoint inputs; hidden from assistive tech. *@

<span aria-hidden="true" data-navius-date-range-picker-separator @attributes="Attributes">@ChildContent</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
