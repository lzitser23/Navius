@namespace Navius.Primitives.Components.ColorPicker
@inherits ColorPickerTrackPart

@*
    The optional alpha channel: a horizontal track (checkerboard under a
    transparent -> opaque gradient of the current color) with a role="slider"
    thumb. Same keyboard spine as the hue slider (1% step; Shift/Page 10%;
    Home/End to the extremes). Only meaningful when the picker has AlphaEnabled;
    the helm renders it conditionally.
*@

<div @ref="TrackElement"
     data-navius-color-picker-alpha
     data-orientation="horizontal"
     data-disabled="@(Context.Disabled ? "" : null)"
     style="@MergedStyle"
     @attributes="Forwarded">
    <span role="slider"
          tabindex="@TabIndex"
          aria-label="Alpha"
          aria-orientation="horizontal"
          aria-valuemin="0"
          aria-valuemax="100"
          aria-valuenow="@AlphaPercent"
          aria-valuetext="@($"{AlphaPercent}% opacity")"
          aria-disabled="@(Context.Disabled ? "true" : null)"
          data-navius-color-picker-alpha-thumb
          data-dragging="@(Dragging ? "" : null)"
          data-disabled="@(Context.Disabled ? "" : null)"
          style="@ThumbStyle"
          @onkeydown="OnKeyDownAsync"></span>
</div>

@code {
    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const double Step = 0.01;
    private const double LargeStep = 0.1;

    protected override Task HandleFractionAsync(double x, double y)
        => Context.SetAlphaAsync(x);

    private int AlphaPercent => (int)Math.Round(Context.A * 100);

    private string TabIndex => Context.Disabled ? "-1" : "0";

    private string ThumbStyle =>
        $"position:absolute;left:{Context.AlphaThumbLeft};top:50%;transform:translate(-50%,-50%);touch-action:none;";

    private const string Checkerboard =
        "conic-gradient(#ccc 25%, transparent 0 50%, #ccc 0 75%, transparent 0) 0 0 / 8px 8px #fff";

    private string MergedStyle
    {
        get
        {
            var (r, g, b) = Context.Rgb;
            var gradient = $"linear-gradient(to right, rgba({r}, {g}, {b}, 0), rgb({r}, {g}, {b}))";
            var baseStyle = $"position:relative;touch-action:none;background:{gradient}, {Checkerboard};";
            var user = UserStyle;
            return string.IsNullOrEmpty(user) ? baseStyle : $"{baseStyle}{user}";
        }
    }

    private string? UserStyle =>
        Attributes is not null && Attributes.TryGetValue("style", out var s) && s is string str && str.Length > 0 ? str : null;

    private IDictionary<string, object>? Forwarded
    {
        get
        {
            if (Attributes is null || !Attributes.ContainsKey("style"))
            {
                return Attributes;
            }

            var copy = new Dictionary<string, object>(Attributes);
            copy.Remove("style");
            return copy;
        }
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        if (Context.Disabled || Context.ReadOnly)
        {
            return;
        }

        var step = e.ShiftKey ? LargeStep : Step;
        var a = Context.A;

        switch (e.Key)
        {
            case "ArrowRight":
            case "ArrowUp": a += step; break;
            case "ArrowLeft":
            case "ArrowDown": a -= step; break;
            case "PageUp": a += LargeStep; break;
            case "PageDown": a -= LargeStep; break;
            case "Home": a = 0; break;
            case "End": a = 1; break;
            default: return;
        }

        await Context.SetAlphaAsync(ColorMath.Clamp01(a));
    }
}
