@namespace Navius.Primitives.Components.ScrollArea
@implements IDisposable
@implements IAsyncDisposable
@inject IJSRuntime JS

@*
    The draggable handle inside a Scrollbar. Sizes and positions itself from the
    metrics the root computed: along its axis, length = sizeRatio of the track and
    offset = offsetRatio of the remaining travel. The size/position is the only
    inline style we emit (geometry, not aesthetics — it is derived state, akin to
    the spec exposing thumb geometry via `--scroll-area-thumb-width/height`; emitting
    those vars is a tracked delta). Visibility follows the parent scrollbar's
    data-hovering/data-scrolling.

    Pointer-drag is delegated to the engine's `dragScrollThumb` export: on pointerdown
    it captures the pointer and maps thumb motion back onto viewport.scrollTop/Left. The
    thumb imports the engine module directly (rather than through the NaviusJsInterop
    bridge) and wires the dragger in OnAfterRenderAsync. If that call fails the thumb is
    still correctly sized and tracks scrolling — only the drag gesture is inert.

    ZERO styling beyond the derived geometry. Bring your own thumb classes
    (background, radius, etc.).
*@

<div @ref="_element"
     data-navius-scrollarea-thumb
     data-orientation="@Orientation"
     data-scrolling="@(Context.Scrolling ? "" : null)"
     style="@ThumbStyle"
     @attributes="Attributes">
</div>

@code {
    private const string ModulePath = "./_content/Navius.Primitives/navius-interop.js";
    private const string VendoredModulePath = "./navius-interop.js";

    // Package mode serves the engine under _content/Navius.Primitives/ (the RCL static web
    // assets). Vendored mode (the registry CLI) copies navius-interop.js into the app's own
    // wwwroot at the root. Try the package path first; on import failure fall back to the
    // vendored path, letting a genuine failure of that import propagate to the caller.
    private static async Task<IJSObjectReference> ImportModuleAsync(IJSRuntime js)
    {
        try
        {
            return await js.InvokeAsync<IJSObjectReference>("import", ModulePath);
        }
        catch (JSException)
        {
            return await js.InvokeAsync<IJSObjectReference>("import", VendoredModulePath);
        }
    }

    [CascadingParameter] private ScrollAreaContext Context { get; set; } = default!;

    [CascadingParameter(Name = "ScrollAreaScrollbarOrientation")]
    private string Orientation { get; set; } = "vertical";

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private ElementReference _element;
    private DotNetObjectReference<NaviusScrollAreaThumb>? _selfRef;
    private IJSObjectReference? _module;
    private IJSObjectReference? _dragger;
    private Func<Task>? _onChange;

    /// <summary>
    /// Inline geometry. For a vertical thumb we drive height + top; horizontal drives
    /// width + left. Expressed in percentages of the track so it stays correct as the
    /// track resizes. top/left = offsetRatio scaled by the leftover (1 - sizeRatio).
    /// </summary>
    private string ThumbStyle
    {
        get
        {
            var size = Context.ThumbSizeRatio(Orientation);
            var offset = Context.ThumbOffsetRatio(Orientation);
            var sizePct = (size * 100).ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
            var offsetPct = (offset * (1 - size) * 100).ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);

            return Orientation == "horizontal"
                ? $"position:absolute;width:{sizePct}%;left:{offsetPct}%;"
                : $"position:absolute;height:{sizePct}%;top:{offsetPct}%;";
        }
    }

    protected override void OnInitialized()
    {
        _onChange = () => InvokeAsync(StateHasChanged);
        Context.Changed += _onChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Create the dragger ONCE, after the thumb element exists and the viewport is
        // registered. The engine's dragScrollThumb attaches its own pointerdown listener;
        // wiring it here (rather than lazily inside an @onpointerdown round-trip) means
        // the listener is live before the user's first press, so dragging starts on the
        // very first pointerdown (the spec behaviour) instead of needing a throwaway press.
        if (_dragger is not null || !Context.HasViewport)
        {
            return;
        }

        try
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            _module ??= await ImportModuleAsync(JS);
            _dragger = await _module.InvokeAsync<IJSObjectReference>(
                "dragScrollThumb", Context.ViewportElement, _element, Orientation);
        }
        catch (JSException)
        {
            // Drag wiring failed — wheel/keyboard/touch scrolling still work.
        }
    }

    public void Dispose()
    {
        if (_onChange is not null)
        {
            Context.Changed -= _onChange;
        }
    }

    public async ValueTask DisposeAsync()
    {
        Dispose();

        if (_dragger is not null)
        {
            try
            {
                await _dragger.InvokeVoidAsync("destroy");
                await _dragger.DisposeAsync();
            }
            catch (JSException) { }
            catch (JSDisconnectedException) { }
        }

        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }

        _selfRef?.Dispose();
    }
}
