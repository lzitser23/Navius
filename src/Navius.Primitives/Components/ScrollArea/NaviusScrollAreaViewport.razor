@namespace Navius.Primitives.Components.ScrollArea
@implements IAsyncDisposable
@inject IJSRuntime JS

@*
    The actual scroll container: overflow:auto so content scrolls natively (keyboard,
    wheel, touch, trackpad all work for free). After first render it asks the engine
    to observe this element and report {scrollTop,scrollHeight,clientHeight,...} on
    every scroll and resize, which the root turns into thumb geometry. The inner
    content wrapper is what actually overflows.

    ZERO styling, but for this to function the consumer MUST give this element
    `overflow: auto` (or the orientation-specific overflow) and a bounded size, e.g.
    `class="h-full w-full overflow-auto"`.
*@

<div @ref="_element"
     data-navius-scrollarea-viewport
     @attributes="Attributes">
    <div data-navius-scrollarea-content>
        @ChildContent
    </div>
</div>

@code {
    private const string ModulePath = "./_content/Navius.Primitives/navius-interop.js";
    private const string VendoredModulePath = "./navius-interop.js";

    // Package mode serves the engine under _content/Navius.Primitives/ (the RCL static web
    // assets). Vendored mode (the registry CLI) copies navius-interop.js into the app's own
    // wwwroot at the root. Try the package path first; on import failure fall back to the
    // vendored path, letting a genuine failure of that import propagate to the caller.
    private static async Task<IJSObjectReference> ImportModuleAsync(IJSRuntime js)
    {
        try
        {
            return await js.InvokeAsync<IJSObjectReference>("import", ModulePath);
        }
        catch (JSException)
        {
            return await js.InvokeAsync<IJSObjectReference>("import", VendoredModulePath);
        }
    }

    [CascadingParameter] private ScrollAreaContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private ElementReference _element;
    private DotNetObjectReference<NaviusScrollAreaViewport>? _selfRef;
    private IJSObjectReference? _module;
    private IJSObjectReference? _observer;
    private Func<Task>? _onChange;
    private bool _engaged;

    protected override void OnInitialized()
    {
        _onChange = () => InvokeAsync(StateHasChanged);
        Context.Changed += _onChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _engaged)
        {
            return;
        }

        _engaged = true;
        Context.ViewportElement = _element;
        Context.HasViewport = true;
        _selfRef = DotNetObjectReference.Create(this);

        // Import the engine module directly (rather than via the NaviusJsInterop bridge)
        // and call its `observeScrollArea` export, which reports viewport metrics back
        // here on every scroll/resize and drives the live thumb. Wrapped in a try/catch
        // so a failed call degrades gracefully.
        try
        {
            _module = await ImportModuleAsync(JS);
            _observer = await _module.InvokeAsync<IJSObjectReference>(
                "observeScrollArea", _element, _selfRef);
        }
        catch (JSException)
        {
            // Engine call failed — native overflow still scrolls; thumb stays at
            // its zero geometry until metrics arrive.
        }
    }

    /// <summary>Invoked from the engine on every scroll / resize with fresh viewport metrics.</summary>
    [JSInvokable]
    public Task OnScrollMetrics(ScrollAreaContext.ScrollMetrics metrics) =>
        Context.SetMetricsAsync(metrics);

    /// <summary>
    /// Invoked from the engine on every native scroll event (in addition to metrics):
    /// reveals the scrollbar just-in-time and arms the hide-delay timer, so
    /// <c>type="scroll"</c> shows only while scrolling and <c>type="hover"</c> also
    /// reveals during scroll (the spec scrollHideDelay model).
    /// </summary>
    [JSInvokable]
    public Task OnScrollActivity() => Context.NotifyScrollActivityAsync();

    public async ValueTask DisposeAsync()
    {
        if (_onChange is not null)
        {
            Context.Changed -= _onChange;
        }

        if (_observer is not null)
        {
            try
            {
                await _observer.InvokeVoidAsync("destroy");
                await _observer.DisposeAsync();
            }
            catch (JSException) { }
            catch (JSDisconnectedException) { }
        }

        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }

        _selfRef?.Dispose();
    }
}
