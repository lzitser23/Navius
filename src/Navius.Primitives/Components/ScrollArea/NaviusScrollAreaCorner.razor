@namespace Navius.Primitives.Components.ScrollArea
@inherits ScrollAreaPart

@*
    The little square where the vertical and horizontal scrollbars meet. the spec only
    renders it when BOTH axes overflow (otherwise there is no gap to fill). Purely
    presentational — no role, no aria. ZERO styling: consumers position it in the
    corner and give it a background.
*@

@if (Context.ShowCorner)
{
    <div data-navius-scrollarea-corner
         @attributes="Attributes">
    </div>
}

@code {
    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
