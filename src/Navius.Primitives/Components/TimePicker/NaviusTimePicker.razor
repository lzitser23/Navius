@namespace Navius.Primitives.Components.TimePicker
@inherits ComponentBase
@using System.Globalization

@*
    Elective (not part of Base UI). TimePicker = an editable segmented time input + a popover
    holding one scrollable listbox column per unit (hours, minutes, optional seconds, optional
    AM/PM). Reuses the Popover engine for anchoring + the dismissable layer (wrapped here so the
    root owns a single open state). Controlled via @bind-Value (TimeOnly?) / @bind-Open,
    uncontrolled via DefaultValue / DefaultOpen. Keyboard entry works without opening the popup.
*@

<CascadingValue Value="_ctx" IsFixed="true">
    <NaviusPopover Open="@CurrentOpen" OpenChanged="RequestOpenAsync" Modal="false">
        @ChildContent
    </NaviusPopover>
</CascadingValue>

@code {
    /// <summary>Controlled value. Use <c>@bind-Value</c>.</summary>
    [Parameter] public TimeOnly? Value { get; set; }

    [Parameter] public EventCallback<TimeOnly?> ValueChanged { get; set; }

    /// <summary>Uncontrolled initial value.</summary>
    [Parameter] public TimeOnly? DefaultValue { get; set; }

    /// <summary>Controlled open state. Use <c>@bind-Open</c>.</summary>
    [Parameter] public bool Open { get; set; }

    [Parameter] public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>Uncontrolled initial open state.</summary>
    [Parameter] public bool DefaultOpen { get; set; }

    [Parameter] public string Granularity { get; set; } = "minute";

    [Parameter] public int? HourCycle { get; set; }

    [Parameter] public int MinuteStep { get; set; } = 1;

    [Parameter] public int SecondStep { get; set; } = 1;

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    private readonly TimePickerContext _ctx = new();

    private TimeOnly? _internalValue;
    private bool _internalOpen;
    private bool _valueSet;
    private bool _openSet;

    private bool IsValueControlled => _valueSet;
    private bool IsOpenControlled => _openSet;
    private TimeOnly? CurrentValue => IsValueControlled ? Value : _internalValue;
    private bool CurrentOpen => IsOpenControlled ? Open : _internalOpen;
    private int ResolvedHourCycle => HourCycle ?? (CultureInfo.CurrentCulture.DateTimeFormat.ShortTimePattern.Contains('H') ? 24 : 12);

    public override Task SetParametersAsync(ParameterView parameters)
    {
        if (parameters.TryGetValue<TimeOnly?>(nameof(Value), out _)) _valueSet = true;
        if (parameters.TryGetValue<bool>(nameof(Open), out _)) _openSet = true;
        return base.SetParametersAsync(parameters);
    }

    protected override void OnInitialized()
    {
        _internalValue = DefaultValue;
        _internalOpen = DefaultOpen;
        _ctx.SetValueImpl = ApplyValueAsync;
    }

    protected override void OnParametersSet() => SyncContext();

    private void SyncContext()
    {
        _ctx.Value = CurrentValue;
        _ctx.HourCycle = ResolvedHourCycle;
        _ctx.Granularity = Granularity;
        _ctx.MinuteStep = Math.Max(1, MinuteStep);
        _ctx.SecondStep = Math.Max(1, SecondStep);
        _ctx.Disabled = Disabled;
    }

    private async Task ApplyValueAsync(TimeOnly? value)
    {
        if (!IsValueControlled)
        {
            _internalValue = value;
        }

        SyncContext();
        await ValueChanged.InvokeAsync(value);
        await _ctx.NotifyAsync();
        StateHasChanged();
    }

    private async Task RequestOpenAsync(bool open)
    {
        if (!IsOpenControlled)
        {
            _internalOpen = open;
        }

        await OpenChanged.InvokeAsync(open);
        StateHasChanged();
    }
}
