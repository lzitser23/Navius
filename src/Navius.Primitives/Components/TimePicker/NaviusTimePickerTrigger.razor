@namespace Navius.Primitives.Components.TimePicker
@inherits ComponentBase

@*
    The clock button that toggles the popup. Delegates to the Popover trigger, which already
    carries aria-haspopup="dialog" + aria-expanded + aria-controls + the discrete
    data-popup-open marker; this adds the data-navius-time-picker-trigger test hook.
*@

<NaviusPopoverTrigger data-navius-time-picker-trigger disabled="@(Ctx.Disabled ? "" : null)" @attributes="Attributes">
    @ChildContent
</NaviusPopoverTrigger>

@code {
    [CascadingParameter] public TimePickerContext Ctx { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
