@namespace Navius.Primitives.Components.TimePicker
@inherits ComponentBase

@*
    Portals + anchors the popup (reusing the Popover engine's Portal > Positioner > Popup),
    then hosts the column listboxes. The Popup is role="dialog" and gets the discrete
    data-navius-time-picker-popup test hook. Enter/exit animation keys off the engine's
    data-open / data-closed / data-starting-style / data-ending-style on the Popup.
*@

<NaviusPopoverPortal>
    <NaviusPopoverPositioner Side="@Side" Align="@Align" SideOffset="SideOffset">
        <NaviusPopoverPopup data-navius-time-picker-popup @attributes="Attributes">
            @ChildContent
        </NaviusPopoverPopup>
    </NaviusPopoverPositioner>
</NaviusPopoverPortal>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string Side { get; set; } = "bottom";

    [Parameter] public string Align { get; set; } = "start";

    [Parameter] public double SideOffset { get; set; } = 4;

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
