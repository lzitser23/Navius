@namespace Navius.Primitives.Components.NavigationMenu
@inherits NavigationMenuPart

@*
    Base UI's NavigationMenu.Icon — a presentational chevron slot inside the Trigger. It
    mirrors the owning item's open state via data-popup-open (present while that item is
    open) so the consumer can rotate/animate the chevron. aria-hidden so assistive tech
    ignores it. ZERO styling.
*@

<span aria-hidden="true"
      data-popup-open="@(IsOpen ? "" : null)"
      data-navius-navigationmenu-icon
      @attributes="Attributes">
    @ChildContent
</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    [CascadingParameter] private NaviusNavigationMenuItem? Item { get; set; }

    private bool IsOpen => Item is not null && Context.IsOpen(Item.Value);
}
