@namespace Navius.Primitives.Components.NavigationMenu
@implements IAsyncDisposable

@*
    Base UI's NavigationMenu.Arrow: a marker inside the Popup that the positioner aligns to
    point at the ACTIVE trigger. It replaces the former Indicator (whose data-state was the
    library's last rendered data-state) — the engine keeps it centred on the active trigger
    and offset to the side, so no state tracking is needed here. Registers its element into
    the context so the Popup wires it into the positioner. Carries data-side (mirrored by
    the engine). No data-state. Headless default: a downward triangle.
*@

<svg @ref="_element"
     width="@Width"
     height="@Height"
     viewBox="0 0 30 10"
     preserveAspectRatio="none"
     data-navius-navigationmenu-arrow
     style="pointer-events:none"
     @attributes="Attributes">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        <polygon points="0,0 30,0 15,10" />
    }
</svg>

@code {
    [CascadingParameter] private NavigationMenuContext Context { get; set; } = default!;

    [Parameter] public double Width { get; set; } = 10;

    [Parameter] public double Height { get; set; } = 5;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private ElementReference _element;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Context.RegisterArrowAsync(_element);
        }
    }

    public async ValueTask DisposeAsync() => await Context.UnregisterArrowAsync(_element);
}
