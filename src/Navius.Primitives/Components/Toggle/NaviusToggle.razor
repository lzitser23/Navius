@namespace Navius.Primitives.Components.Toggle
<button type="button"
        aria-pressed="@(CurrentPressed ? "true" : "false")"
        data-pressed="@(CurrentPressed ? "" : null)"
        data-disabled="@(Disabled ? "" : null)"
        data-navius-toggle
        disabled="@Disabled"
        @onclick="ToggleAsync"
        @attributes="Attributes">@ChildContent</button>
@code {
    [Parameter] public bool Pressed { get; set; }
    [Parameter] public EventCallback<bool> PressedChanged { get; set; }
    [Parameter] public bool DefaultPressed { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
    private bool _internalPressed;
    private bool IsControlled => PressedChanged.HasDelegate;
    private bool CurrentPressed => IsControlled ? Pressed : _internalPressed;
    protected override void OnInitialized() => _internalPressed = DefaultPressed;
    private async Task ToggleAsync() {
        if (Disabled) return;
        var next = !CurrentPressed;
        if (IsControlled) await PressedChanged.InvokeAsync(next); else _internalPressed = next;
    }
}
