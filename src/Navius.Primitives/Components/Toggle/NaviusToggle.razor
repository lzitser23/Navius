@namespace Navius.Primitives.Components.Toggle
<button type="button"
        aria-pressed="@(CurrentPressed ? "true" : "false")"
        data-pressed="@(CurrentPressed ? "" : null)"
        data-disabled="@(Disabled ? "" : null)"
        data-navius-toggle
        disabled="@Disabled"
        @onclick="ToggleAsync"
        @attributes="Attributes">@ChildContent</button>
@code {
    [Parameter] public bool Pressed { get; set; }
    [Parameter] public EventCallback<bool> PressedChanged { get; set; }
    [Parameter] public bool DefaultPressed { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
    private bool _internalPressed;
    // Controlled-ness is determined by whether Pressed was explicitly supplied (tracked in
    // SetParametersAsync), NOT by PressedChanged.HasDelegate.
    private bool _pressedSet;
    private bool IsControlled => _pressedSet;
    private bool CurrentPressed => IsControlled ? Pressed : _internalPressed;

    public override Task SetParametersAsync(ParameterView parameters) {
        if (parameters.TryGetValue<bool>(nameof(Pressed), out _)) _pressedSet = true;
        return base.SetParametersAsync(parameters);
    }

    protected override void OnInitialized() => _internalPressed = DefaultPressed;
    private async Task ToggleAsync() {
        if (Disabled) return;
        var next = !CurrentPressed;
        if (IsControlled) {
            await PressedChanged.InvokeAsync(next);
        } else {
            _internalPressed = next;
            // Surface the change to observers even when uncontrolled (the spec's onPressedChange).
            if (PressedChanged.HasDelegate) await PressedChanged.InvokeAsync(next);
        }
    }
}
