@namespace Navius.Primitives.Components.Accordion
@inherits AccordionPart

@*
    One accordion section. Nesting is Item > Header > Trigger (+ Content). Cascades its
    Value and its disabled state to the trigger/content so they don't need them passed
    explicitly. Exposes data-state / data-disabled / data-orientation on the wrapper.
*@

<CascadingValue Value="Value" Name="NaviusAccordionItemValue" IsFixed="true">
    <CascadingValue Value="Disabled" Name="NaviusAccordionItemDisabled" IsFixed="false">
        <div data-navius-accordion-item
             data-open="@(Context.IsOpen(Value) ? "" : null)"
             data-disabled="@(IsDisabled ? "" : null)"
             data-index="@Context.IndexOf(Value)"
             @attributes="Attributes">
            @ChildContent
        </div>
    </CascadingValue>
</CascadingValue>

@code {
    [Parameter] public string Value { get; set; } = "";

    /// <summary>Disables this section: its trigger can't toggle or be focused; data-disabled is emitted.</summary>
    [Parameter] public bool Disabled { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private bool IsDisabled => Context.IsItemDisabled(Disabled);
}
