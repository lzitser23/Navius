@namespace Navius.Primitives.Components.Combobox
@inherits ComboboxPart

@*
    The Base UI Combobox.Clear — clears the whole selection AND the filter, then returns
    focus to the input. tabindex=-1 so it stays out of the Tab order.
*@

<button type="button"
        tabindex="-1"
        data-disabled="@(Context.Disabled ? "" : null)"
        data-navius-combobox-clear
        @onclick="OnClickAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private async Task OnClickAsync()
    {
        await Context.ClearAsync();
        if (Context.HasTrigger)
        {
            try { await Context.TriggerElement.FocusAsync(); } catch { /* input may be gone */ }
        }
    }
}
