@namespace Navius.Primitives.Components.Combobox
@inherits ComboboxPart

@*
    The Base UI Combobox.Status — an aria-live region announcing the result count to
    assistive tech. Renders ChildContent when supplied, else an auto count message.
*@

<div role="status" aria-live="polite" data-navius-combobox-status @attributes="Attributes">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        @($"{Context.ItemCount} result{(Context.ItemCount == 1 ? "" : "s")}")
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
