@namespace Navius.Primitives.Components.Combobox
@inherits Navius.Primitives.Components.Overlays.OverlayPresence

@*
    The Base UI Combobox.Backdrop — an optional overlay behind the popup. A non-modal
    combobox usually has none, so this is a thin parity part built on the shared presence
    machine: C# owns the discrete data-open/data-closed + data-starting-style/
    data-ending-style; there is no scroll lock / focus trap (the combobox is non-modal).
    Place inside a Portal if used.
*@

@if (Rendered)
{
    <div @ref="Element"
         data-open="@(Context.Open ? "" : null)"
         data-closed="@(Context.Open ? null : "")"
         data-starting-style="@(Entering ? "" : null)"
         data-ending-style="@(Exiting ? "" : null)"
         data-navius-combobox-backdrop
         @attributes="Attributes"></div>
}

@code {
    [CascadingParameter] private ComboboxContext Context { get; set; } = default!;

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    protected override IOverlayContext OverlayContext => Context;
}
