@namespace Navius.Primitives.Components.Combobox
@inherits ComboboxPart

@*
    The Base UI Combobox.Empty — shown only when the popup is open and there are no filtered
    rows (e.g. "No results"). Sits alongside the List inside the Popup.
*@

@if (Context.Open && Context.IsEmpty)
{
    <div data-navius-combobox-empty @attributes="Attributes">@ChildContent</div>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
