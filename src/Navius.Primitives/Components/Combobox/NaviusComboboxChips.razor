@namespace Navius.Primitives.Components.Combobox
@inherits ComboboxPart

@*
    The Base UI Combobox.Chips — the container for the selected chips (multi-select). Mirrors
    the List's boxed-render approach: it iterates the committed SelectedValues and renders the
    Root's per-chip callback (the consumer's ChipTemplate, else a default chip = label +
    remove). Only meaningful when Multiple.
*@

<div data-navius-combobox-chips @attributes="Attributes">
    @if (Context.RenderChip is not null)
    {
        @foreach (var value in Context.SelectedValues)
        {
            @Context.RenderChip(value)
        }
    }
</div>

@code {
    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
