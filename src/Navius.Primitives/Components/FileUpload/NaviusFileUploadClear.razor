@namespace Navius.Primitives.Components.FileUpload
@inherits FileUploadPart

@* Clears all selected files. Disabled when the list is already empty. *@

<button type="button"
        disabled="@IsDisabled"
        data-navius-file-upload-clear
        data-disabled="@(IsDisabled ? "" : null)"
        @onclick="Context.ClearAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private bool IsDisabled => Context.Disabled || Context.Files.Count == 0;
}
