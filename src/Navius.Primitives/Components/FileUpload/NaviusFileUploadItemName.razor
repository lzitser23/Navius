@namespace Navius.Primitives.Components.FileUpload
@inherits ComponentBase

@* The file name (defaults to the file's name; override with children). *@

<span data-navius-file-upload-item-name @attributes="Attributes">@(ChildContent ?? DefaultName)</span>

@code {
    [CascadingParameter] private FileUploadItemContext Item { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private RenderFragment DefaultName => builder => builder.AddContent(0, Item.File.Name);
}
