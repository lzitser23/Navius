@namespace Navius.Primitives.Components.FileUpload
@inherits ComponentBase

@* The human-readable file size (e.g. "1.4 KB"). *@

<span data-navius-file-upload-item-size @attributes="Attributes">@FileUploadContext.FormatSize(Item.File.Size)</span>

@code {
    [CascadingParameter] private FileUploadItemContext Item { get; set; } = default!;

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
