@namespace Navius.Primitives.Components.FileUpload
@inherits FileUploadPart

@*
    A plain button that opens the OS file dialog by relaying to the hidden input
    (native button keyboard). react-aria FileTrigger pattern.
*@

<button type="button"
        disabled="@Context.Disabled"
        data-navius-file-upload-trigger
        data-disabled="@(Context.Disabled ? "" : null)"
        @onclick="OpenAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private Task OpenAsync() => Context.Disabled ? Task.CompletedTask : Context.OpenAsync();
}
