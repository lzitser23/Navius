@namespace Navius.Primitives.Components.Drawer
@inherits DrawerPart

@* The button that opens the drawer (the spec Drawer.Trigger). Emits discrete data-popup-open. *@

<button type="button"
        @ref="_element"
        aria-haspopup="dialog"
        aria-expanded="@(Context.Open ? "true" : "false")"
        aria-controls="@Context.ContentId"
        data-popup-open="@(Context.Open ? "" : null)"
        data-navius-drawer-trigger
        @onclick="Context.RequestToggleAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    private ElementReference _element;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Context.TriggerElement = _element;
            Context.HasTrigger = true;
        }
    }
}
