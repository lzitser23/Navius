@namespace Navius.Primitives.Components.Drawer

@* The spec Drawer.Close. Any button inside the popup that closes the drawer. *@

<button type="button"
        data-navius-drawer-close
        @onclick="Context.RequestCloseAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    [CascadingParameter] private DrawerContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
