@namespace Navius.Primitives.Components.Toast
@inherits ComponentBase

@*
    A composable close button. Renders your own content (icon/label) and closes the
    toast on click. Mirrors the spec's Toast.Close. (Full asChild parity — merging this
    behaviour onto an arbitrary child element — remains gated on the Slot/asChild
    Blazor limitation; ChildContent composition is provided here.)
*@

<button type="button"
        data-navius-toast-close
        @onclick="Context.RequestCloseAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    [CascadingParameter] private ToastContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
