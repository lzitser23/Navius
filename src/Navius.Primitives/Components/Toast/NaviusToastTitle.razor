@namespace Navius.Primitives.Components.Toast
@inherits ComponentBase
@implements IDisposable

@*
    The toast's title. Carries the id referenced by the Root's aria-labelledby so
    the toast is announced title-first. Mirrors the spec's Toast.Title.
*@

<div id="@Context.TitleId" data-navius-toast-title @attributes="Attributes">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        @Context.Toast?.Title
    }
</div>

@code {
    [CascadingParameter] private ToastContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    protected override void OnInitialized() => Context.HasTitle = true;

    public void Dispose() => Context.HasTitle = false;
}
