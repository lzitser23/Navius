@namespace Navius.Primitives.Components.Toast
@inherits ComponentBase

@*
    An actionable button inside a toast (e.g. "Undo"). Mirrors the Base UI Toast.Action:
    activating it runs the handler then closes the toast, and AltText is required to provide
    an accessible alternative for screen-reader / hotkey users who can't perform the gesture.
    When manager-driven and given no ChildContent/OnClick, it renders the toast's
    ToastActionProps (label + handler).
*@

<button type="button"
        data-navius-toast-action
        @onclick="OnClickAsync"
        @attributes="Attributes">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        @ManagerAction?.Label
    }
</button>

@code {
    [CascadingParameter] private ToastContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Required. A plain-text description of the action for assistive tech and for the
    /// alternative way to perform it. Falls back to the manager action's alt text.
    /// </summary>
    [Parameter] public string AltText { get; set; } = string.Empty;

    /// <summary>Optional consumer click handler, invoked before the toast closes.</summary>
    [Parameter] public EventCallback OnClick { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private ToastActionProps? ManagerAction => Context.Toast?.Action;

    private async Task OnClickAsync()
    {
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync();
        }
        else if (ManagerAction?.OnClick is not null)
        {
            await ManagerAction.OnClick.Invoke();
        }
        await Context.RequestCloseAsync();
    }
}
