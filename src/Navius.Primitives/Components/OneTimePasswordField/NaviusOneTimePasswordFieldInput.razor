@namespace Navius.Primitives.Components.OneTimePasswordField
@inherits OneTimePasswordFieldPart

@*
    A single character cell of the OTP field. inputmode + autocomplete=one-time-code let mobile
    keyboards and SMS autofill target the group. maxlength=1 keeps each cell to one glyph;
    aria-label="Character N of M" names the slot for screen readers. type=password masks the glyph
    when the root requests it.

    Keyboard (mirrors the spec OneTimePasswordField + the APG text-input conventions):
      - typing a char       -> writes this cell and advances focus to the next cell
      - Backspace           -> clears the focused char (or the previous when empty) and retreats
      - Cmd/Ctrl+Backspace  -> clears the whole field and focuses the first cell
      - Delete              -> clears the focused char and shifts the remainder back
      - Arrow prev/next      -> ArrowUp/Down when vertical (default), ArrowLeft/Right when horizontal
      - Home/End            -> jump to first / last cell
      - Enter               -> submits the owning form
      - Paste               -> replaces the entire field with the pasted code from slot 0
                               (SMS autofill into a single cell delivers the whole code the same way)
*@

<input @ref="_element"
       type="@Context.Type"
       inputmode="@Context.InputMode"
       autocomplete="one-time-code"
       maxlength="@(Index == 0 ? Context.Length : 1)"
       value="@Context.CharAt(Index)"
       placeholder="@Context.Placeholder"
       aria-label="@($"Character {Index + 1} of {Context.Length}")"
       disabled="@Context.Disabled"
       readonly="@Context.ReadOnly"
       data-navius-otp-input
       data-index="@Index"
       data-filled="@(string.IsNullOrEmpty(Context.CharAt(Index)) ? null : "")"
       data-orientation="@Context.Orientation"
       data-disabled="@(Context.Disabled ? "" : null)"
       data-readonly="@(Context.ReadOnly ? "" : null)"
       @oninput="OnInputAsync"
       @onkeydown="OnKeyDownAsync"
       @attributes="Attributes" />

@code {
    /// <summary>Zero-based slot this cell occupies within the field.</summary>
    [Parameter] public int Index { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private ElementReference _element;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Context.RegisterCell(Index, _element);
        }
    }

    private Task OnInputAsync(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? string.Empty;

        // A value longer than one character is a paste / autofill: it replaces the whole field.
        // A single character is an ordinary keystroke for this cell.
        return raw.Length > 1
            ? Context.PasteAsync(Index, raw)
            : Context.SetCharAsync(Index, raw);
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        var vertical = !string.Equals(Context.Orientation, "horizontal", StringComparison.Ordinal);

        switch (e.Key)
        {
            case "Backspace":
                await Context.KeyAsync(Index, KeyKind.Backspace, e.MetaKey || e.CtrlKey);
                break;
            case "Delete":
                await Context.KeyAsync(Index, KeyKind.Delete, false);
                break;
            case "ArrowUp" when vertical:
            case "ArrowLeft" when !vertical:
                await Context.KeyAsync(Index, KeyKind.Prev, false);
                break;
            case "ArrowDown" when vertical:
            case "ArrowRight" when !vertical:
                await Context.KeyAsync(Index, KeyKind.Next, false);
                break;
            case "Home":
                await Context.KeyAsync(Index, KeyKind.First, false);
                break;
            case "End":
                await Context.KeyAsync(Index, KeyKind.Last, false);
                break;
            case "Enter":
                await Context.SubmitAsync();
                break;
        }
    }
}
