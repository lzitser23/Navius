@namespace Navius.Primitives.Components.OneTimePasswordField
@inherits ComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JS

@*
    Root of a one-time-password field. role=group labels the cluster of single-character
    inputs as one control (mirrors the spec OneTimePasswordField.Root). Controlled via
    @bind-Value (string) or uncontrolled via DefaultValue. The aggregate value is the
    concatenation of the per-cell characters; a hidden input carries it for form posts.

    By default the root renders the Length cells itself with sensible OTP attributes. To
    customise the cell markup, supply ChildContent and place NaviusOneTimePasswordFieldInput
    elements yourself (each binds to its own Index). A NaviusOneTimePasswordFieldHiddenInput
    part may also be placed inside; if Name is set and no explicit part is present, the root
    renders an implicit hidden input.
*@

<CascadingValue Value="_context" IsFixed="true">
    <div role="group"
         data-navius-otp
         data-orientation="@Orientation"
         data-disabled="@(Disabled ? "" : null)"
         @attributes="Attributes">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            @for (var i = 0; i < Length; i++)
            {
                <NaviusOneTimePasswordFieldInput Index="i" />
            }
        }
        @* In auto-render mode emit a hidden input for form posts. In ChildContent mode the
           consumer composes NaviusOneTimePasswordFieldHiddenInput themselves. *@
        @if (ChildContent is null && !string.IsNullOrEmpty(Name))
        {
            <NaviusOneTimePasswordFieldHiddenInput Name="@Name" Form="@Form" />
        }
    </div>
</CascadingValue>

@code {
    /// <summary>Number of single-character cells (and the maximum value length). Default 6.</summary>
    [Parameter] public int Length { get; set; } = 6;

    /// <summary>Controlled aggregate value. Provide together with <see cref="ValueChanged"/>.</summary>
    [Parameter] public string? Value { get; set; }

    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>Initial aggregate value for uncontrolled use.</summary>
    [Parameter] public string? DefaultValue { get; set; }

    /// <summary>Disables every cell.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Marks every cell read-only.</summary>
    [Parameter] public bool ReadOnly { get; set; }

    /// <summary><c>inputmode</c> for each cell. Default <c>"numeric"</c>.</summary>
    [Parameter] public string InputMode { get; set; } = "numeric";

    /// <summary>
    /// Accepted character class: <c>"numeric"</c> (default), <c>"alpha"</c> or
    /// <c>"alphanumeric"</c>. Input outside the class is rejected (mirrors the spec validationType).
    /// </summary>
    [Parameter] public string ValidationType { get; set; } = "numeric";

    /// <summary>
    /// Optional transform applied to each character / pasted value before it is stored
    /// (mirrors the spec sanitizeValue). Runs after <see cref="ValidationType"/> filtering.
    /// </summary>
    [Parameter] public Func<string, string>? SanitizeValue { get; set; }

    /// <summary>Rendered cell type: <c>"text"</c> (default) or <c>"password"</c> to mask glyphs.</summary>
    [Parameter] public string Type { get; set; } = "text";

    /// <summary>Navigation orientation: <c>"vertical"</c> (default) or <c>"horizontal"</c>.</summary>
    [Parameter] public string Orientation { get; set; } = "vertical";

    /// <summary>Placeholder applied to empty cells.</summary>
    [Parameter] public string? Placeholder { get; set; }

    /// <summary>Focus the first cell on mount when <c>true</c>.</summary>
    [Parameter] public bool AutoFocus { get; set; }

    /// <summary>Optional form field name for the hidden input that carries the aggregate value.</summary>
    [Parameter] public string? Name { get; set; }

    /// <summary>Id of the form to associate the hidden input with when it sits outside that form.</summary>
    [Parameter] public string? Form { get; set; }

    /// <summary>When <c>true</c>, submit the owning form once every cell is filled (mirrors the spec autoSubmit).</summary>
    [Parameter] public bool AutoSubmit { get; set; }

    /// <summary>Raised with the value when the field is filled and <see cref="AutoSubmit"/> fires.</summary>
    [Parameter] public EventCallback<string> OnAutoSubmit { get; set; }

    /// <summary>Raised when the whole field is filled (every cell occupied).</summary>
    [Parameter] public EventCallback<string> OnComplete { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private OneTimePasswordFieldContext _context = default!;
    private ElementReference?[] _refs = Array.Empty<ElementReference?>();
    private string _internal = string.Empty;
    private NaviusJsInterop? _interop;
    private bool _shouldAutoFocus;

    // Controlled-ness is determined by whether a non-null Value was explicitly supplied
    // (tracked in SetParametersAsync), NOT by ValueChanged.HasDelegate.
    private bool _valueSet;
    private bool IsControlled => _valueSet;
    private string CurrentValue => IsControlled ? (Value ?? string.Empty) : _internal;

    public override Task SetParametersAsync(ParameterView parameters)
    {
        if (parameters.TryGetValue<string?>(nameof(Value), out var v) && v is not null)
        {
            _valueSet = true;
        }

        return base.SetParametersAsync(parameters);
    }

    protected override void OnInitialized()
    {
        _internal = DefaultValue ?? string.Empty;
        _shouldAutoFocus = AutoFocus;
        _refs = new ElementReference?[Length];
        _context = new OneTimePasswordFieldContext(
            Length, Disabled, ReadOnly, InputMode, Type, Orientation, Placeholder,
            SetCharAsync, FocusIndexAsync, PasteFromAsync, RegisterCell,
            HandleKeyAsync, RequestSubmitAsync);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_refs.Length != Length)
        {
            Array.Resize(ref _refs, Length);
        }

        _context.Reconfigure(Length, Disabled, ReadOnly, InputMode, Type, Orientation, Placeholder);
        await _context.SetValueInternalAsync(CurrentValue);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _shouldAutoFocus)
        {
            _shouldAutoFocus = false;
            await FocusIndexAsync(0);
        }
    }

    /// <summary>Cells call this (via the context) to register their <see cref="ElementReference"/>.</summary>
    private void RegisterCell(int index, ElementReference element)
    {
        if (index >= 0 && index < _refs.Length)
        {
            _refs[index] = element;
        }
    }

    private async Task FocusIndexAsync(int index)
    {
        var clamped = Math.Clamp(index, 0, Length - 1);
        if (_refs.Length > clamped && _refs[clamped] is { } el)
        {
            try { await el.FocusAsync(); }
            catch { /* element not yet rendered */ }
        }
    }

    /// <summary>
    /// Apply a single keystroke to cell <paramref name="index"/>. We take the last character of
    /// the raw input (so typing over a filled cell replaces it), reject disallowed characters,
    /// and advance focus on success.
    /// </summary>
    private async Task SetCharAsync(int index, string raw)
    {
        if (Disabled || ReadOnly)
        {
            return;
        }

        var sanitized = Sanitize(string.IsNullOrEmpty(raw) ? string.Empty : raw[^1].ToString());
        var ch = sanitized.Length == 0 ? (char?)null : sanitized[^1];

        // A non-empty keystroke that yields no accepted character is rejected outright: leave the
        // buffer untouched (don't clear a filled cell, don't advance focus). Genuine clears arrive
        // as an empty raw value (handled via Backspace/Delete, not here).
        if (ch is null && !string.IsNullOrEmpty(raw))
        {
            // Re-render so the rejected glyph the browser optimistically painted is reverted.
            StateHasChanged();
            return;
        }

        var next = ReplaceAt(CurrentValue, index, ch);
        await CommitAsync(next);

        if (ch is not null && index < Length - 1)
        {
            await FocusIndexAsync(index + 1);
        }
    }

    /// <summary>
    /// Paste replaces the ENTIRE field (the spec overwrites all cells regardless of the focused
    /// one), writing the sanitized value from slot 0 and landing focus on the last filled cell.
    /// </summary>
    private async Task PasteFromAsync(int index, string text)
    {
        if (Disabled || ReadOnly || string.IsNullOrEmpty(text))
        {
            return;
        }

        var clean = Sanitize(text);
        if (clean.Length > Length)
        {
            clean = clean[..Length];
        }

        await CommitAsync(clean);
        await FocusIndexAsync(Math.Min(clean.Length, Length - 1));
    }

    /// <summary>Navigation / edit keys forwarded from a cell, branched on orientation/modifier.</summary>
    private async Task HandleKeyAsync(int index, KeyKind kind, bool modifier)
    {
        switch (kind)
        {
            case KeyKind.Prev:
                await FocusIndexAsync(index - 1);
                break;
            case KeyKind.Next:
                await FocusIndexAsync(index + 1);
                break;
            case KeyKind.First:
                await FocusIndexAsync(0);
                break;
            case KeyKind.Last:
                await FocusIndexAsync(Length - 1);
                break;
            case KeyKind.Backspace:
                await BackspaceAsync(index, modifier);
                break;
            case KeyKind.Delete:
                await DeleteAsync(index);
                break;
        }
    }

    /// <summary>
    /// Backspace. Cmd/Ctrl+Backspace clears the whole field and lands on the first cell.
    /// Otherwise: a non-empty focused cell is cleared (and shifts the remainder back) and focus
    /// retreats; an empty focused cell clears the previous cell and retreats — a single-keystroke
    /// clear-and-retreat matching the spec.
    /// </summary>
    private async Task BackspaceAsync(int index, bool modifier)
    {
        if (Disabled || ReadOnly)
        {
            return;
        }

        if (modifier)
        {
            await CommitAsync(string.Empty);
            await FocusIndexAsync(0);
            return;
        }

        if (!string.IsNullOrEmpty(_context.CharAt(index)))
        {
            await CommitAsync(RemoveAt(CurrentValue, index));
            await FocusIndexAsync(index - 1);
            return;
        }

        if (index > 0)
        {
            await CommitAsync(RemoveAt(CurrentValue, index - 1));
            await FocusIndexAsync(index - 1);
        }
    }

    /// <summary>Delete clears the focused character and shifts the remaining characters back.</summary>
    private async Task DeleteAsync(int index)
    {
        if (Disabled || ReadOnly || string.IsNullOrEmpty(_context.CharAt(index)))
        {
            return;
        }

        await CommitAsync(RemoveAt(CurrentValue, index));
    }

    /// <summary>Enter / completed autoSubmit: request submission of the closest form.</summary>
    private async Task RequestSubmitAsync()
    {
        if (Disabled)
        {
            return;
        }

        try
        {
            _interop ??= new NaviusJsInterop(JS);
            if (_refs.Length > 0 && _refs[0] is { } first)
            {
                await _interop.SubmitClosestFormAsync(first);
            }
        }
        catch { /* no owning form / JS unavailable */ }
    }

    private async Task CommitAsync(string next)
    {
        if (IsControlled)
        {
            await ValueChanged.InvokeAsync(next);
        }
        else
        {
            _internal = next;
            await _context.SetValueInternalAsync(next);
            if (ValueChanged.HasDelegate)
            {
                // Surface the change to observers even when uncontrolled (the spec's onValueChange).
                await ValueChanged.InvokeAsync(next);
            }
            StateHasChanged();
        }

        // Complete only when every slot holds a real character (no interior gaps).
        if (next.Length >= Length && !next.Contains(' '))
        {
            if (OnComplete.HasDelegate)
            {
                await OnComplete.InvokeAsync(next);
            }

            if (AutoSubmit)
            {
                if (OnAutoSubmit.HasDelegate)
                {
                    await OnAutoSubmit.InvokeAsync(next);
                }

                await RequestSubmitAsync();
            }
        }
    }

    /// <summary>Apply <see cref="ValidationType"/> filtering then <see cref="SanitizeValue"/>.</summary>
    private string Sanitize(string input)
    {
        if (string.IsNullOrEmpty(input))
        {
            return SanitizeValue is not null ? SanitizeValue(string.Empty) : string.Empty;
        }

        var filtered = new string(input.Where(IsAllowed).ToArray());
        return SanitizeValue is not null ? SanitizeValue(filtered) : filtered;
    }

    private bool IsAllowed(char c) => ValidationType switch
    {
        "alpha" => char.IsLetter(c),
        "alphanumeric" => char.IsLetterOrDigit(c),
        _ => char.IsDigit(c),
    };

    private char[] ToBuffer(string value)
    {
        var buffer = new char[Length];
        for (var i = 0; i < Length; i++)
        {
            buffer[i] = i < value.Length ? value[i] : '\0';
        }

        return buffer;
    }

    /// <summary>
    /// Write <paramref name="ch"/> into slot <paramref name="index"/>, keeping interior empties as
    /// real gaps so each slot maps to its data-index. Only trailing empties are trimmed; interior
    /// NULs are preserved as spaces in the dense string so positions never collapse.
    /// </summary>
    private string ReplaceAt(string value, int index, char? ch)
    {
        var buffer = ToBuffer(value);
        if (index >= 0 && index < Length)
        {
            buffer[index] = ch ?? '\0';
        }

        return Densify(buffer);
    }

    /// <summary>Remove the character at <paramref name="index"/> and shift later chars back one slot.</summary>
    private string RemoveAt(string value, int index)
    {
        var buffer = ToBuffer(value);
        if (index >= 0 && index < Length)
        {
            for (var i = index; i < Length - 1; i++)
            {
                buffer[i] = buffer[i + 1];
            }

            buffer[Length - 1] = '\0';
        }

        return Densify(buffer);
    }

    /// <summary>
    /// Collapse a positional buffer into the aggregate string. Trailing empties are dropped;
    /// interior empties become spaces so the prefix length (and therefore each slot index) is
    /// preserved when the value is pushed back through the context.
    /// </summary>
    private static string Densify(char[] buffer)
    {
        var end = buffer.Length;
        while (end > 0 && buffer[end - 1] == '\0')
        {
            end--;
        }

        var chars = new char[end];
        for (var i = 0; i < end; i++)
        {
            chars[i] = buffer[i] == '\0' ? ' ' : buffer[i];
        }

        return new string(chars);
    }

    public async ValueTask DisposeAsync()
    {
        if (_interop is not null)
        {
            await _interop.DisposeAsync();
        }
    }
}
