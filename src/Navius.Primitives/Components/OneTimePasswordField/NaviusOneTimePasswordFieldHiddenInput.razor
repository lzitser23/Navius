@namespace Navius.Primitives.Components.OneTimePasswordField
@inherits OneTimePasswordFieldPart

@*
    A first-class, composable hidden input carrying the concatenated OTP value for real form
    submission (mirrors the spec OneTimePasswordField.HiddenInput). Re-renders with the buffer via
    OneTimePasswordFieldPart, so its value always reflects the current aggregate (filled cells,
    no interior gaps). Place it anywhere inside Root; set Name for the field name and Form to
    associate it with a form by id when it sits outside that form.
*@

<input type="hidden"
       name="@Name"
       value="@Context.Value"
       form="@Form"
       data-navius-otp-hidden
       @attributes="Attributes" />

@code {
    /// <summary>Form field name submitted with the owning form.</summary>
    [Parameter] public string? Name { get; set; }

    /// <summary>Id of an associated form element when the input is outside that form.</summary>
    [Parameter] public string? Form { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
