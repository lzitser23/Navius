@namespace Navius.Primitives.Components.AlertDialog

@*
    The cancelling action (e.g. "Cancel"). Closes the dialog and is the control
    that receives initial focus (per the APG — the least destructive action).
    Registers its ElementReference with the context so the content can focus it.
    Lives inside the content.
*@

<button @ref="_element"
        type="button"
        data-navius-alert-dialog-cancel
        @onclick="Context.RequestCloseAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    [CascadingParameter] private AlertDialogContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private ElementReference _element;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Context.CancelElement = _element;
            Context.HasCancel = true;
        }
    }
}
