@namespace Navius.Primitives.Components.AlertDialog

@*
    The confirming action (e.g. "Delete"). Closes the dialog. Consumers wire their
    own destructive logic via @onclick (it runs alongside the close request) or by
    handling state after close. Lives inside the content.
*@

<button type="button"
        data-navius-alert-dialog-action
        @onclick="Context.RequestCloseAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    [CascadingParameter] private AlertDialogContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
