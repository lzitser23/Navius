@namespace Navius.Primitives.Components.AlertDialog
@inherits ComponentBase

@*
    Root of the alert dialog. Owns the open state (controlled via @bind-Open, or
    uncontrolled via DefaultOpen) and cascades an AlertDialogContext to its parts.
    Renders no DOM of its own — headless to the core.
*@

<CascadingValue Value="_context" IsFixed="true">
    @ChildContent
</CascadingValue>

@code {
    private AlertDialogContext _context = default!;
    private bool _internalOpen;

    /// <summary>Controlled open state. Use with <see cref="OpenChanged"/> (i.e. @bind-Open).</summary>
    [Parameter] public bool Open { get; set; }

    [Parameter] public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>Initial open state when used uncontrolled (no @bind-Open).</summary>
    [Parameter] public bool DefaultOpen { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    // Controlled-ness is determined by whether Open was explicitly supplied (tracked in
    // SetParametersAsync), NOT by OpenChanged.HasDelegate.
    private bool _openSet;
    private bool IsControlled => _openSet;

    public override Task SetParametersAsync(ParameterView parameters)
    {
        if (parameters.TryGetValue<bool>(nameof(Open), out _))
        {
            _openSet = true;
        }

        return base.SetParametersAsync(parameters);
    }

    protected override void OnInitialized()
    {
        _internalOpen = DefaultOpen;
        _context = new AlertDialogContext(RequestSetAsync);
    }

    protected override async Task OnParametersSetAsync()
    {
        // Flow the authoritative value into the context (no-op if unchanged).
        var authoritative = IsControlled ? Open : _internalOpen;
        await _context.SetOpenInternalAsync(authoritative);
    }

    private async Task RequestSetAsync(bool value)
    {
        if (IsControlled)
        {
            // Let the parent flip Open; it flows back through OnParametersSetAsync.
            await OpenChanged.InvokeAsync(value);
        }
        else
        {
            _internalOpen = value;
            await _context.SetOpenInternalAsync(value);
            if (OpenChanged.HasDelegate)
            {
                // Surface the change to observers even when uncontrolled (the spec's onOpenChange).
                await OpenChanged.InvokeAsync(value);
            }
            StateHasChanged();
        }
    }
}
