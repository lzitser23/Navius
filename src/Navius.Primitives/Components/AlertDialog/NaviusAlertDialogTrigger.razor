@namespace Navius.Primitives.Components.AlertDialog
@inherits AlertDialogPart

@*
    The button that opens the alert dialog. Brings the behaviour + ARIA; the
    consumer brings the class. Captures its own ElementReference so focus can be
    restored here when the dialog closes.
*@

<button @ref="_element"
        type="button"
        aria-haspopup="dialog"
        aria-expanded="@(Context.Open ? "true" : "false")"
        aria-controls="@Context.ContentId"
        data-popup-open="@(Context.Open ? "" : null)"
        data-navius-alert-dialog-trigger
        @onclick="OpenAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private ElementReference _element;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Context.TriggerElement = _element;
            Context.HasTrigger = true;
        }
    }

    private Task OpenAsync() => Context.RequestSetAsync(true);
}
