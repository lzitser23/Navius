@namespace Navius.Primitives.Components.Progress

@* Base UI Progress.Label — an accessible label; the Root wires aria-labelledby to it. *@
<span id="@Context.LabelId"
      data-complete="@Context.DataComplete"
      data-indeterminate="@Context.DataIndeterminate"
      data-progressing="@Context.DataProgressing"
      data-navius-progress-label
      @attributes="Attributes">@ChildContent</span>

@code {
    [CascadingParameter] private ProgressContext Context { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    protected override void OnInitialized() => Context.SetHasLabel();
}
