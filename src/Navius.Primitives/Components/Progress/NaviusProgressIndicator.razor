@namespace Navius.Primitives.Components.Progress

<div data-complete="@Context.DataComplete"
     data-indeterminate="@Context.DataIndeterminate"
     data-progressing="@Context.DataProgressing"
     data-value="@Context.DataValue"
     data-max="@Context.DataMax"
     data-navius-progress-indicator
     @attributes="Attributes">
    @ChildContent
</div>

@code {
    [CascadingParameter] private ProgressContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
