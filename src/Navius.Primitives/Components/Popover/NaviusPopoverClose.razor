@namespace Navius.Primitives.Components.Popover

@* Any button inside the content that should close the popover. *@

<button type="button"
        data-navius-popover-close
        @onclick="Context.RequestCloseAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    [CascadingParameter] private PopoverContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
