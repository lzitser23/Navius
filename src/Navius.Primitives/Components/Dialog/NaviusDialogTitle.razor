@namespace Navius.Primitives.Components.Dialog
@implements IDisposable

@* Labels the dialog (aria-labelledby points here). Lives inside the content. *@

<h2 id="@Context.TitleId" data-navius-dialog-title @attributes="Attributes">@ChildContent</h2>

@code {
    [CascadingParameter] private DialogContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    protected override void OnInitialized() => Context.RegisterTitle();

    public void Dispose() => Context.UnregisterTitle();
}
