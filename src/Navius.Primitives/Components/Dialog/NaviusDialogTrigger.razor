@namespace Navius.Primitives.Components.Dialog
@inherits DialogPart

@*
    The button that opens the dialog. Brings the behaviour + ARIA; the consumer
    brings the class. Unmatched attributes (class, id, ...) are forwarded so the
    styled "helm" layer lives entirely in user code.
*@

<button type="button"
        @ref="_element"
        aria-haspopup="dialog"
        aria-expanded="@(Context.Open ? "true" : "false")"
        aria-controls="@Context.ContentId"
        data-popup-open="@(Context.Open ? "" : null)"
        data-navius-dialog-trigger
        @onclick="Context.RequestToggleAsync"
        @attributes="Attributes">
    @ChildContent
</button>

@code {
    private ElementReference _element;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // Captured so the content's dismissable layer treats clicks on the
            // trigger as "inside" (a toggling trigger must not re-close instantly).
            Context.TriggerElement = _element;
            Context.HasTrigger = true;
        }
    }
}
