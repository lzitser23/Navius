@namespace Navius.Primitives.Components.Dialog
@implements IDisposable

@* Describes the dialog (aria-describedby points here). Lives inside the content. *@

<p id="@Context.DescriptionId" data-navius-dialog-description @attributes="Attributes">@ChildContent</p>

@code {
    [CascadingParameter] private DialogContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    protected override void OnInitialized() => Context.RegisterDescription();

    public void Dispose() => Context.UnregisterDescription();
}
