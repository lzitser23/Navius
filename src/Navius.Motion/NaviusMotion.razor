@namespace Navius.Motion
@inject IJSRuntime JS
@implements IAsyncDisposable

@*
    Declarative enter-animation wrapper: renders a single div (ADR-0003 limits, no
    asChild) and plays the preset's enter animation through the WAAPI tier on first
    render. The spring is solved and baked in C#; JS only executes. For zero-wrapper
    usage splat Motion.Enter(...) onto your own element (CSS tier); for open/close
    animation of primitives use Motion.Presence(...) or CreatePresenceMotionAsync.
*@

<div @ref="_element" data-navius-motion @attributes="Attributes">@ChildContent</div>

@code {
    private ElementReference _element;
    private MotionJsInterop? _interop;
    private MotionAnimation? _animation;

    /// <summary>The enter preset to play on first render.</summary>
    [Parameter] public Preset Preset { get; set; } = Preset.Fade;

    /// <summary>Optional spring override for the preset's enter phase.</summary>
    [Parameter] public Spring? Spring { get; set; }

    /// <summary>Delay before the enter animation starts, in milliseconds.</summary>
    [Parameter] public double Delay { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Splatted onto the rendered element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            _interop ??= new MotionJsInterop(JS);
            var (keyframes, options) = MotionPrograms.Enter(MotionPresets.Get(Preset), Spring, Delay);
            _animation = await _interop.AnimateElementAsync(_element, keyframes, options);
        }
        catch (JSException)
        {
            // Engine unavailable (no module, prerender edge): degrade to no animation.
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_animation is not null)
        {
            await _animation.DisposeAsync();
            _animation = null;
        }
        if (_interop is not null)
        {
            await _interop.DisposeAsync();
            _interop = null;
        }
        GC.SuppressFinalize(this);
    }
}
