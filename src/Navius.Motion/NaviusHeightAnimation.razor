@namespace Navius.Motion
@using System.Threading.Tasks
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using Navius.Motion.Interop
@inject IJSRuntime JS
@implements IAsyncDisposable

@*
    Auto-height container: renders one overflow-clipped element (ADR-0003 limits, no asChild)
    around an inner measured wrapper, and WAAPI-tweens the outer height so a collapse/expand or
    a content-size change resizes smoothly instead of jumping. Splat @attributes onto the outer
    element to supply class/layout. Duration/Easing time the tween, or pass a Spring to animate
    it on a baked linear() spring. Physics are solved and baked in C#; JS only executes.

    One nullable flag distinguishes the two modes: Expanded = null (default) always tracks the
    content's natural size (never collapses); Expanded = true/false is collapse/expand between 0
    and the natural height, and content-tracking still applies while expanded.

    Simplification (stated, not a Collapsible replacement): collapsed content stays mounted and
    in the tab order (visually hidden via overflow:hidden + height:0); this does NOT manage
    inert/hidden/tabindex. For an accessibility-gated collapse use NaviusCollapsible.
*@

<div @ref="_element" data-navius-height-animation style="overflow:hidden" @attributes="Attributes">
    <div @ref="_content" data-navius-height-animation-content>
        @ChildContent
    </div>
</div>

@code {
    private ElementReference _element;
    private ElementReference _content;
    private MotionJsInterop? _interop;
    private HeightAnimationMotion? _handle;
    private bool? _lastExpanded;

    /// <summary>
    /// null (default) = always track content size (never collapses). true/false =
    /// collapse/expand between 0 and the natural height (tracking still applies while true).
    /// </summary>
    [Parameter] public bool? Expanded { get; set; }

    /// <summary>Tween duration in milliseconds. Ignored when <see cref="Spring"/> is set. Defaults to 300.</summary>
    [Parameter] public double? Duration { get; set; }

    /// <summary>Tween easing (a CSS easing keyword or a baked <c>linear()</c> string). Defaults to <c>ease</c>.</summary>
    [Parameter] public string? Easing { get; set; }

    /// <summary>Spring for the tween: baked to a <c>linear()</c> easing and settle duration. Overrides the defaults.</summary>
    [Parameter] public Spring? Spring { get; set; }

    /// <summary>Reduced-motion mode: <c>user</c> (OS setting), <c>always</c>, or <c>never</c>.</summary>
    [Parameter] public string ReduceMotion { get; set; } = "user";

    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Splatted onto the rendered outer container element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (firstRender)
            {
                _interop ??= new MotionJsInterop(JS);
                _handle = await _interop.CreateHeightAnimationAsync(
                    _element, _content,
                    MotionPrograms.HeightAnimation(Spring, Duration, Easing, ReduceMotion, Expanded));
                _lastExpanded = Expanded;
            }
            else if (_handle is not null && Expanded != _lastExpanded)
            {
                _lastExpanded = Expanded;
                await _handle.SetExpandedAsync(Expanded);
            }
        }
        catch (JSException)
        {
            // Engine unavailable (no module, prerender edge): degrade to no animation.
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_handle is not null)
        {
            await _handle.DisposeAsync();
            _handle = null;
        }
        if (_interop is not null)
        {
            await _interop.DisposeAsync();
            _interop = null;
        }
        GC.SuppressFinalize(this);
    }
}
