@page "/motion"
@namespace Navius.Playground.Pages
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

@*
    Navius.Motion (M0-b): the presence + gesture engine wired onto real primitives.
    Two tiers are on show. The CSS tier is the generated navius-motion.css: presence
    classes (motion-pop / motion-fade / motion-slide-up) ride the discrete state
    attributes every Navius popup already emits, so exits cooperate with the presence
    machine's deferred unmount with zero JavaScript. The runtime tier is the WAAPI
    executor reached through MotionJsInterop: CreatePresenceMotionAsync for an overlay
    animated by a C#-baked spring, and CreateGestureAsync for the press micro-interaction.
    Overlays that animate their transform are centred with the independent `translate`
    property so the animated `transform` stays free.
*@

<style>
    /* Runtime-tier overlay is keep-mounted; hide it while closed (the WAAPI exit holds
       the hidden state once it has run at least once, this covers the first paint). */
    [data-motion-runtime][data-closed] { opacity: 0; pointer-events: none; }
</style>

<div class="min-h-screen bg-background text-foreground p-10 space-y-10" data-motion-page>
    <header class="space-y-1">
        <h1 class="text-2xl font-semibold tracking-tight">Motion</h1>
        <p class="text-sm text-muted-foreground">
            Springs solved and baked in C#, executed on the compositor. Presence presets on real
            primitives (CSS tier), a WAAPI overlay and a press gesture (runtime tier), and a declarative
            enter wrapper with a spring picker.
        </p>
    </header>

    <section class="space-y-3">
        <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Presence · CSS tier on real primitives</h2>
        <div class="flex flex-wrap items-center gap-3">
            <NaviusDialog @bind-Open="_dialogOpen">
                <NaviusDialogTrigger data-testid="motion-dialog-trigger"
                                     class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                    Open dialog (pop)
                </NaviusDialogTrigger>

                <NaviusDialogBackdrop class="motion-fade fixed inset-0 z-50 bg-black/70 backdrop-blur-sm" />

                <NaviusDialogPopup data-testid="motion-dialog-popup"
                                   class="motion-pop fixed left-1/2 top-1/2 z-50 w-[calc(100%-2rem)] max-w-md rounded-xl border border-border bg-card p-6 text-card-foreground shadow-2xl focus:outline-none"
                                   style="translate: -50% -50%">
                    <NaviusDialogTitle class="text-lg font-semibold leading-none tracking-tight">Pop preset.</NaviusDialogTitle>
                    <NaviusDialogDescription class="mt-2 text-sm text-muted-foreground">
                        Fades and scales from 0.9 with the bouncy spring on enter, snappy on exit. The presence
                        machine keeps this node mounted through the exit transition, then unmounts it.
                    </NaviusDialogDescription>
                    <div class="mt-6 flex justify-end">
                        <NaviusDialogClose data-testid="motion-dialog-close"
                                           class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                            Close
                        </NaviusDialogClose>
                    </div>
                </NaviusDialogPopup>
            </NaviusDialog>

            <button type="button" data-testid="dialog-stress" @onclick="RapidToggleDialog"
                    class="inline-flex h-10 items-center justify-center rounded-md border border-input bg-background px-5 text-sm font-medium shadow-sm transition-colors hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Rapid toggle
            </button>

            <NaviusMenu>
                <NaviusMenuTrigger data-testid="motion-menu-trigger"
                                   class="inline-flex h-10 items-center justify-center rounded-md border border-input bg-background px-5 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                    Open menu (fade)
                </NaviusMenuTrigger>
                <NaviusMenuPositioner Side="bottom" Align="start">
                    <NaviusMenuPopup data-testid="motion-menu-popup"
                                     class="motion-fade z-50 min-w-[12rem] rounded-md border border-border bg-card p-1 text-card-foreground shadow-lg outline-none">
                        <NaviusMenuItem class="flex cursor-default select-none items-center rounded-sm px-2 py-1.5 text-sm outline-none focus:bg-accent focus:text-accent-foreground">Profile</NaviusMenuItem>
                        <NaviusMenuItem class="flex cursor-default select-none items-center rounded-sm px-2 py-1.5 text-sm outline-none focus:bg-accent focus:text-accent-foreground">Billing</NaviusMenuItem>
                        <NaviusMenuItem class="flex cursor-default select-none items-center rounded-sm px-2 py-1.5 text-sm outline-none focus:bg-accent focus:text-accent-foreground">Settings</NaviusMenuItem>
                    </NaviusMenuPopup>
                </NaviusMenuPositioner>
            </NaviusMenu>

            <NaviusTooltip OpenDelay="120">
                <NaviusTooltipTrigger data-testid="motion-tooltip-trigger"
                                      class="inline-flex h-10 items-center justify-center rounded-md border border-input bg-background px-5 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                    Hover me (slide)
                </NaviusTooltipTrigger>
                <NaviusTooltipPositioner Side="top">
                    <NaviusTooltipPopup data-testid="motion-tooltip-popup"
                                        class="motion-slide-up z-50 rounded-md bg-foreground px-3 py-1.5 text-xs font-medium text-background shadow-md">
                        Fades and slides up 24px in.
                    </NaviusTooltipPopup>
                </NaviusTooltipPositioner>
            </NaviusTooltip>
        </div>
    </section>

    <section class="space-y-3">
        <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Presence · runtime tier (WAAPI, bouncy spring)</h2>
        <button type="button" data-testid="runtime-toggle" @onclick="ToggleRuntime"
                class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            Toggle runtime overlay
        </button>
        <div @ref="_runtimeEl" data-testid="runtime-popup" data-motion-runtime
             data-open="@(_runtimeOpen ? "" : null)"
             data-closed="@(_runtimeOpen ? null : "")"
             data-starting-style="@(_runtimeEntering ? "" : null)"
             data-ending-style="@(_runtimeExiting ? "" : null)"
             class="fixed left-1/2 top-1/2 z-50 w-72 rounded-xl border border-border bg-card p-6 text-sm text-card-foreground shadow-2xl"
             style="translate: -50% -50%">
            <p class="font-medium">Runtime tier</p>
            <p class="mt-1 text-muted-foreground">
                Enter is a bouncy spring baked to a linear() run in C# and executed with the Web Animations
                API. Interruptions hand over from the live computed transform.
            </p>
        </div>
    </section>

    <section class="space-y-3">
        <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Gestures</h2>
        <div class="flex flex-wrap items-center gap-6">
            <button type="button" data-testid="press-button" @ref="_pressEl"
                    class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground shadow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Press me (scale)
            </button>

            @* CSS tier: Motion.Hover splats the motion-hover class + the lift CSS var.
               Fully qualified because this page's own type is also named Motion. *@
            <div @attributes="global::Navius.Motion.Motion.Hover(6)" data-testid="hover-card">
                <div class="w-56 cursor-default rounded-xl border border-border bg-card p-6 text-sm text-card-foreground shadow">
                    Hover to lift
                </div>
            </div>
        </div>
    </section>

    <section class="space-y-3" data-testid="micro-section">
        <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Micro pack · attention &amp; ambient</h2>
        <div class="flex flex-wrap items-start gap-8">
            @* Shake on a fake validation (runtime tier): submitting empty shakes the field once. *@
            <div class="flex flex-col gap-2">
                <div @ref="_shakeEl" data-testid="shake-field" class="flex flex-col gap-1">
                    <label for="motion-email" class="text-xs font-medium text-muted-foreground">Email</label>
                    <input id="motion-email" data-testid="shake-input" @bind="_email" @bind:event="oninput"
                           placeholder="you@example.com"
                           class="h-9 w-56 rounded-md border border-input bg-background px-3 text-sm shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" />
                </div>
                <button type="button" data-testid="shake-submit" @onclick="SubmitEmail"
                        class="inline-flex h-9 w-56 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                    Submit
                </button>
                @if (_emailError)
                {
                    <p data-testid="shake-error" class="text-xs text-destructive">Email is required.</p>
                }
            </div>

            @* Pulse live-status dot (runtime loop, start/stop). *@
            <div class="flex flex-col gap-2">
                <div class="flex items-center gap-2">
                    <span @ref="_pulseEl" data-testid="pulse-dot" class="inline-block h-3 w-3 rounded-full bg-primary"></span>
                    <span class="text-sm">Live status</span>
                </div>
                <button type="button" data-testid="pulse-toggle" @onclick="TogglePulse"
                        class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                    @(_pulsing ? "Stop" : "Start")
                </button>
            </div>

            @* Shimmer sweep (CSS tier): the motion-shimmer class merges with the surface styles. *@
            <div class="flex flex-col gap-2">
                <div data-testid="shimmer-block" class="motion-shimmer h-16 w-56 rounded-md bg-muted"></div>
                <p class="text-xs text-muted-foreground">Skeleton shimmer</p>
            </div>

            @* Focus-glow hairline ring (CSS tier). *@
            <div class="flex flex-col gap-2">
                <div data-testid="focus-glow-el" class="motion-focus-glow grid h-16 w-40 place-items-center rounded-md border border-border bg-card text-sm text-card-foreground">
                    Focus glow
                </div>
                <p class="text-xs text-muted-foreground">Hairline emphasis</p>
            </div>
        </div>
    </section>

    <section class="space-y-3">
        <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Enter wrapper · spring picker</h2>
        <div class="flex flex-wrap items-center gap-6">
            <div class="flex flex-col gap-2">
                <NaviusMotion @key="_wrapperReplay" Preset="Preset.SlideUp" Spring="_wrapperSpring"
                              data-testid="wrapper-el"
                              class="block w-64 rounded-xl border border-border bg-card p-6 text-sm text-card-foreground shadow">
                    Enters with the <strong>@_wrapperSpringName</strong> spring.
                </NaviusMotion>
            </div>
            <div class="flex flex-col gap-2">
                <button type="button" data-testid="wrapper-smooth" @onclick="ReplaySmooth"
                        class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                    Smooth
                </button>
                <button type="button" data-testid="wrapper-snappy" @onclick="ReplaySnappy"
                        class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                    Snappy
                </button>
                <button type="button" data-testid="wrapper-bouncy" @onclick="ReplayBouncy"
                        class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                    Bouncy
                </button>
            </div>
        </div>
    </section>

    <section class="space-y-3" data-testid="auto-animate-section">
        <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Auto-animate · FLIP on mutation (runtime tier)</h2>
        <p class="text-sm text-muted-foreground">
            One attribute on the list container. Every add, remove and reorder of its children animates: survivors
            FLIP on a C#-baked <code class="font-mono">linear()</code> spring, new items scale and fade in, removed
            items pin absolute and fade out before detaching.
        </p>
        <div class="flex flex-wrap items-center gap-3">
            <button type="button" data-testid="auto-animate-add" @onclick="AddItem"
                    class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Add
            </button>
            <button type="button" data-testid="auto-animate-remove" @onclick="RemoveItem"
                    class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Remove first
            </button>
            <button type="button" data-testid="auto-animate-shuffle" @onclick="ShuffleItems"
                    class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Shuffle
            </button>
            <button type="button" data-testid="auto-animate-storm" @onclick="StormItems"
                    class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Storm
            </button>
            <span class="font-mono text-xs text-muted-foreground">order: <span data-testid="auto-animate-order">@string.Join(",", _items)</span></span>
        </div>

        <NaviusAutoAnimate Spring="Spring.Default" data-testid="auto-animate-list"
                           class="flex w-64 flex-col gap-2 rounded-lg border border-border bg-muted/30 p-2">
            @foreach (var item in _items)
            {
                <div @key="item" data-testid="auto-animate-item" data-item="@item"
                     class="flex h-10 items-center rounded-md border border-border bg-card px-3 text-sm text-card-foreground shadow-sm">
                    Item @item
                </div>
            }
        </NaviusAutoAnimate>
    </section>

    @* --- M3: selection indicator -------------------------------------------- *@
    <section class="space-y-3" data-testid="selection-section">
        <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Selection indicator · spring marker (runtime tier)</h2>
        <p class="text-sm text-muted-foreground">
            A standalone marker that slides to the active button on a C#-baked spring. Position rides a
            compositor <code class="font-mono">transform</code>; the pill's size animates so it tracks buttons of
            differing width. Resize-aware. Not the Tabs engine: the math is generalized into navius-motion.js.
        </p>
        <div @ref="_selectionRow" data-testid="selection-row"
             class="relative inline-flex items-center gap-1 rounded-lg border border-border bg-muted p-1">
            <NaviusSelectionIndicator Container="_selectionRow" Active="_selected" Spring="Spring.Snappy" Axis="both"
                                      data-testid="selection-indicator"
                                      class="pointer-events-none rounded-md bg-primary shadow" />
            @for (var i = 0; i < _selectionLabels.Length; i++)
            {
                var index = i;
                <button type="button" data-testid="selection-tab" data-tab-index="@index"
                        data-active="@(_selected == index ? "" : null)"
                        @onclick="() => SelectTab(index)"
                        class="relative z-10 rounded-md px-4 py-1.5 text-sm font-medium transition-colors data-[active]:text-primary-foreground">
                    @_selectionLabels[index]
                </button>
            }
        </div>
    </section>

    @* --- M3: sequence executor ---------------------------------------------- *@
    <section class="space-y-3" data-testid="sequence-section">
        <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Sequence · imperative timeline (play / pause / seek)</h2>
        <p class="text-sm text-muted-foreground">
            A <code class="font-mono">MotionSequence</code> composed in C#: four bars rise on a snappy spring, each
            overlapping the previous by 100ms (<code class="font-mono">at: "-100"</code>). The at-offsets resolve to
            absolute start times and springs bake to <code class="font-mono">linear()</code> in C#; JS plays one WAAPI
            animation per segment on a shared clock, so seek is a single scrub.
        </p>
        <div @ref="_sequenceRoot" data-testid="sequence-stage" class="flex h-28 items-end gap-3 rounded-lg border border-border bg-muted/30 p-3">
            @for (var i = 1; i <= 4; i++)
            {
                <div data-seq="@i" data-testid="seq-bar" class="h-full w-12 rounded-md bg-primary"></div>
            }
        </div>
        <div class="flex flex-wrap items-center gap-3">
            <button type="button" data-testid="seq-play" @onclick="SequencePlay"
                    class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Play
            </button>
            <button type="button" data-testid="seq-pause" @onclick="SequencePause"
                    class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Pause
            </button>
            <button type="button" data-testid="seq-seek-end" @onclick="SequenceSeekEnd"
                    class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Seek to end
            </button>
            <button type="button" data-testid="seq-reset" @onclick="SequenceReset"
                    class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Reset
            </button>
            <span class="font-mono text-xs text-muted-foreground">duration: <span data-testid="seq-duration">@_sequenceDuration</span>ms</span>
        </div>
    </section>

    @* --- M3: page transition (same-document, experimental) ------------------- *@
    <section class="space-y-3" data-testid="page-transition-section">
        <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Page transition · same-document (experimental)</h2>
        <p class="text-sm text-muted-foreground">
            <code class="font-mono">NaviusPageTransition</code> registers a NavigationManager location-changing handler and
            snapshots the change through <code class="font-mono">document.startViewTransition</code>. Same-document only;
            with no support or under reduced motion it falls back to instant. This demo navigates a query string
            (<code class="font-mono">?view=</code>) so it stays isolated to this route.
        </p>
        <div class="flex flex-wrap items-center gap-3">
            <button type="button" data-testid="pt-link-a" @onclick='() => Nav.NavigateTo("motion?view=a")'
                    class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                View A
            </button>
            <button type="button" data-testid="pt-link-b" @onclick='() => Nav.NavigateTo("motion?view=b")'
                    class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                View B
            </button>
            <span class="font-mono text-xs text-muted-foreground">view: <span data-testid="pt-current">@(View ?? "a")</span></span>
        </div>
        <NaviusPageTransition>
            <div data-testid="pt-region" style="view-transition-name: navius-pt-demo"
                 class="rounded-lg border border-border bg-card p-6 text-card-foreground shadow">
                @if (View == "b")
                {
                    <div data-testid="pt-view-b" class="space-y-1">
                        <p class="text-lg font-semibold">View B</p>
                        <p class="text-sm text-muted-foreground">The second screen. Navigating here cross-fades from View A.</p>
                    </div>
                }
                else
                {
                    <div data-testid="pt-view-a" class="space-y-1">
                        <p class="text-lg font-semibold">View A</p>
                        <p class="text-sm text-muted-foreground">The first screen. Navigating to View B cross-fades this region.</p>
                    </div>
                }
            </div>
        </NaviusPageTransition>
    </section>

    @* --- M3: in-view reveal + stagger --------------------------------------- *@
    <div style="height: 30vh" aria-hidden="true"></div>
    <section class="space-y-3" data-testid="in-view-section">
        <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">In-view reveal · scroll + stagger (CSS tier)</h2>
        <p class="text-sm text-muted-foreground">
            These cards start hidden and reveal on scroll into view: an IntersectionObserver sets
            <code class="font-mono">data-in-view</code>, the generated <code class="font-mono">.motion-in-view-*</code> classes
            transition them in on the compositor, and a stagger fans <code class="font-mono">--navius-motion-delay</code> across
            them so they arrive in sequence.
        </p>
        <div @ref="_revealGroup" data-testid="reveal-group" class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            @for (var i = 0; i < 6; i++)
            {
                <div data-testid="reveal-item" data-reveal-index="@i"
                     class="motion-in-view-fade-up grid h-24 place-items-center rounded-lg border border-border bg-card text-sm text-card-foreground shadow">
                    Card @(i + 1)
                </div>
            }
        </div>
    </section>

    <p class="font-mono text-xs text-muted-foreground">
        view source · <code>playground/Navius.Playground/Pages/Motion.razor</code>
    </p>
</div>

@code {
    // Dialog: controlled so the stress button can slam its open state.
    private bool _dialogOpen;

    // Runtime-tier overlay state (keep-mounted; we drive the discrete presence attributes
    // ourselves so CreatePresenceMotionAsync's observer runs enter/exit).
    private ElementReference _runtimeEl;
    private bool _runtimeOpen;
    private bool _runtimeEntering;
    private bool _runtimeExiting;
    private bool _runtimeEnterFlip;

    // Gestures + runtime presence live on the JS side through one interop instance.
    private ElementReference _pressEl;
    private MotionJsInterop? _interop;
    private MotionGesture? _press;
    private PresenceMotion? _runtime;

    // Micro pack (runtime tier): a one-shot shake on a fake validation, a looping pulse.
    private ElementReference _shakeEl;
    private ElementReference _pulseEl;
    private MotionMicro? _shake;
    private MotionMicro? _pulse;
    private string _email = "";
    private bool _emailError;
    private bool _pulsing;

    // Enter wrapper picker.
    private int _wrapperReplay;
    private Spring? _wrapperSpring;
    private string _wrapperSpringName = "default";

    // Auto-animate list (FLIP on mutation). @key drives real DOM moves on reorder.
    private readonly List<int> _items = new() { 1, 2, 3, 4, 5 };
    private int _nextId = 6;

    // M3: selection indicator across a row of buttons (the component self-wires).
    private ElementReference _selectionRow;
    private int _selected;
    private readonly string[] _selectionLabels = { "Overview", "Activity", "Settings", "Members" };

    // M3: imperative sequence (four rising bars) with play/pause/seek.
    private ElementReference _sequenceRoot;
    private MotionSequenceHandle? _sequence;
    private int _sequenceDuration;
    private static readonly MotionFrame[] _rise =
    {
        new(Opacity: 0, Transform: "translateY(40px)"),
        new(Opacity: 1, Transform: "translateY(0px)"),
    };

    // M3: in-view reveal with a stagger.
    private ElementReference _revealGroup;
    private InViewMotion? _reveal;

    // M3: page-transition demo view (?view=a|b), same-document via NaviusPageTransition.
    [SupplyParameterFromQuery] public string? View { get; set; }

    private void SelectTab(int index) => _selected = index;

    private async Task SequencePlay()
    {
        if (_sequence is not null) await _sequence.PlayAsync();
    }

    private async Task SequencePause()
    {
        if (_sequence is not null) await _sequence.PauseAsync();
    }

    private async Task SequenceSeekEnd()
    {
        if (_sequence is not null) await _sequence.SeekAsync(_sequence.DurationMs);
    }

    private async Task SequenceReset()
    {
        if (_sequence is not null) await _sequence.StopAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _interop = new MotionJsInterop(JS);
            _press = await _interop.CreateGestureAsync(_pressEl, "press", MotionPrograms.Gesture());
            _runtime = await _interop.CreatePresenceMotionAsync(
                _runtimeEl, MotionPrograms.Presence(MotionPresets.Zoom, enterSpring: Spring.Bouncy));

            _shake = await _interop.CreateMicroAsync(_shakeEl, MotionPrograms.Micro(MicroPresets.Shake));
            _pulse = await _interop.CreateMicroAsync(_pulseEl, MotionPrograms.Micro(MicroPresets.Pulse));
            await _pulse.PlayAsync();   // the live-status dot breathes until stopped
            _pulsing = true;

            // Sequence: four bars rising, each overlapping the previous by 100ms; the
            // at-offsets and spring are compiled to absolute times + linear() in C#.
            var sequence = new MotionSequence()
                .To("[data-seq='1']", _rise, Spring.Snappy)
                .To("[data-seq='2']", _rise, Spring.Snappy, at: "-100")
                .To("[data-seq='3']", _rise, Spring.Snappy, at: "-100")
                .To("[data-seq='4']", _rise, Spring.Snappy, at: "-100");
            _sequence = await _interop.RunSequenceAsync(sequence.Build(), _sequenceRoot);
            _sequenceDuration = (int)_sequence.DurationMs;

            // In-view reveal group with a left-to-right stagger.
            _reveal = await _interop.CreateInViewAsync(
                _revealGroup, new InViewOptions(Amount: 0, Stagger: StaggerOptions.Of(80, StaggerFrom.First)));

            StateHasChanged();          // reflect the running state + sequence duration
        }

        if (_runtimeEnterFlip)
        {
            // Drop data-starting-style one render after opening. The enter animation is
            // already running (started on the attribute's add), so the observer's remove
            // branch skips it; clearing the attribute lets the next open re-trigger.
            _runtimeEnterFlip = false;
            _runtimeEntering = false;
            StateHasChanged();
        }
    }

    private void ToggleRuntime()
    {
        if (_runtimeOpen)
        {
            _runtimeOpen = false;
            _runtimeExiting = true;      // add data-ending-style -> exit plays
            _runtimeEntering = false;
        }
        else
        {
            _runtimeOpen = true;
            _runtimeExiting = false;     // clear data-ending-style from the prior close
            _runtimeEntering = true;     // add data-starting-style -> enter plays
            _runtimeEnterFlip = true;
        }
    }

    private async Task RapidToggleDialog()
    {
        // Slam the controlled open state open/closed repeatedly, faster than the enter
        // (740ms) and exit (270ms) transitions, to drive the presence machine's
        // re-open-mid-exit path and the CSS transition-interruption hotspot. End OPEN.
        for (var i = 0; i < 6; i++)
        {
            _dialogOpen = !_dialogOpen;
            StateHasChanged();
            await Task.Delay(40);
        }
        _dialogOpen = true;
        StateHasChanged();
    }

    private async Task SubmitEmail()
    {
        // Fake validation: an empty field is invalid and shakes once (runtime one-shot).
        if (string.IsNullOrWhiteSpace(_email))
        {
            _emailError = true;
            if (_shake is not null)
            {
                await _shake.PlayAsync();
            }
        }
        else
        {
            _emailError = false;
        }
    }

    private async Task TogglePulse()
    {
        if (_pulse is null)
        {
            return;
        }
        if (_pulsing)
        {
            await _pulse.StopAsync();
            _pulsing = false;
        }
        else
        {
            await _pulse.PlayAsync();
            _pulsing = true;
        }
    }

    private void ReplaySmooth() => ReplayWrapper(Spring.Smooth, "smooth");
    private void ReplaySnappy() => ReplayWrapper(Spring.Snappy, "snappy");
    private void ReplayBouncy() => ReplayWrapper(Spring.Bouncy, "bouncy");

    private void ReplayWrapper(Spring spring, string name)
    {
        _wrapperSpring = spring;
        _wrapperSpringName = name;
        _wrapperReplay++;   // @key change remounts NaviusMotion, replaying the enter
    }

    private void AddItem() => _items.Insert(0, _nextId++);

    private void RemoveItem()
    {
        if (_items.Count > 0)
        {
            _items.RemoveAt(0);
        }
    }

    private void ShuffleItems() => _items.Reverse();

    private async Task StormItems()
    {
        // Slam add / remove / reorder faster than the FLIP settles, to stress the
        // retrigger-cancel path and the exit-clone lifecycle under overlap. Deterministic.
        for (var i = 0; i < 12; i++)
        {
            switch (i % 3)
            {
                case 0:
                    _items.Insert(0, _nextId++);
                    break;
                case 1:
                    if (_items.Count > 1)
                    {
                        _items.RemoveAt(_items.Count - 1);
                    }
                    break;
                default:
                    _items.Reverse();
                    break;
            }
            StateHasChanged();
            await Task.Delay(30);
        }
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_press is not null)
        {
            await _press.DisposeAsync();
            _press = null;
        }
        if (_runtime is not null)
        {
            await _runtime.DisposeAsync();
            _runtime = null;
        }
        if (_shake is not null)
        {
            await _shake.DisposeAsync();
            _shake = null;
        }
        if (_pulse is not null)
        {
            await _pulse.DisposeAsync();
            _pulse = null;
        }
        if (_sequence is not null)
        {
            await _sequence.DisposeAsync();
            _sequence = null;
        }
        if (_reveal is not null)
        {
            await _reveal.DisposeAsync();
            _reveal = null;
        }
        if (_interop is not null)
        {
            await _interop.DisposeAsync();
            _interop = null;
        }
        GC.SuppressFinalize(this);
    }
}
