@page "/extras"
@using Zits.Ui

@* Extras: the two helm-only presentational surfaces, Typography and Timeline. *@

<div class="min-h-screen bg-background text-foreground p-10 space-y-12" data-zits-extras>
    <header class="space-y-1">
        <h1 class="text-2xl font-semibold tracking-tight">zits/ui · extras</h1>
        <p class="text-sm text-muted-foreground">Two helm-only presentational surfaces: the Typography scale and the Timeline set.</p>
    </header>

    <section class="space-y-4" data-testid="typography">
        <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Typography</h2>

        <ZitsTypography Variant="H1">Taxing Laughter: The Joke Tax Chronicles</ZitsTypography>
        <ZitsTypography Variant="H2">The People of the Kingdom</ZitsTypography>
        <ZitsTypography Variant="H3">The Joke Tax</ZitsTypography>
        <ZitsTypography Variant="H4">People stopped telling jokes</ZitsTypography>
        <ZitsTypography Variant="Lead">A modal dialog that interrupts the user with important content and expects a response.</ZitsTypography>
        <ZitsTypography Variant="P">The king, seeing how much happier his subjects were, realized the error of his ways and repealed the joke tax.</ZitsTypography>
        <ZitsTypography Variant="Blockquote">"After all," he said, "everyone enjoys a good joke, so it's only fair that they should pay for the privilege."</ZitsTypography>
        <ZitsTypography Variant="List">
            <li>1st level of puns: 5 gold coins</li>
            <li>2nd level of jokes: 10 gold coins</li>
            <li>3rd level of one-liners: 20 gold coins</li>
        </ZitsTypography>
        <ZitsTypography Variant="Large">Are you absolutely sure?</ZitsTypography>
        <ZitsTypography Variant="Small">Email address</ZitsTypography>
        <ZitsTypography Variant="Muted">Enter your email address.</ZitsTypography>
        <p>
            Run <ZitsTypography Variant="InlineCode" As="code">navius add timeline</ZitsTypography> to install.
        </p>
    </section>

    <section class="space-y-4" data-testid="timeline">
        <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Timeline</h2>

        <ZitsTimeline Orientation="Vertical" Align="Left" class="max-w-md">
            <ZitsTimelineItem Status="complete">
                <ZitsTimelineSeparator>
                    <ZitsTimelineDot Variant="default" />
                    <ZitsTimelineConnector />
                </ZitsTimelineSeparator>
                <ZitsTimelineContent>
                    <ZitsTimelineTime>09:00</ZitsTimelineTime>
                    <ZitsTimelineTitle>Order placed</ZitsTimelineTitle>
                    <ZitsTimelineDescription>We received your order and sent a confirmation email.</ZitsTimelineDescription>
                </ZitsTimelineContent>
            </ZitsTimelineItem>

            <ZitsTimelineItem Status="current">
                <ZitsTimelineSeparator>
                    <ZitsTimelineDot Variant="outline" />
                    <ZitsTimelineConnector />
                </ZitsTimelineSeparator>
                <ZitsTimelineContent>
                    <ZitsTimelineTime>11:30</ZitsTimelineTime>
                    <ZitsTimelineTitle>Packed and dispatched</ZitsTimelineTitle>
                    <ZitsTimelineDescription>Your parcel left the warehouse and is on its way.</ZitsTimelineDescription>
                </ZitsTimelineContent>
            </ZitsTimelineItem>

            <ZitsTimelineItem Status="pending">
                <ZitsTimelineSeparator>
                    <ZitsTimelineDot Variant="muted" />
                </ZitsTimelineSeparator>
                <ZitsTimelineContent>
                    <ZitsTimelineTime datetime="2026-07-10">Expected Fri</ZitsTimelineTime>
                    <ZitsTimelineTitle>Out for delivery</ZitsTimelineTitle>
                    <ZitsTimelineDescription>A courier will deliver the parcel to your address.</ZitsTimelineDescription>
                </ZitsTimelineContent>
            </ZitsTimelineItem>
        </ZitsTimeline>
    </section>
</div>
